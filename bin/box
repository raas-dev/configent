#!/bin/sh

# configent (https://github.com/raas-dev/configent)
# One command automated macOS/Linux laptop/VM/container bootstrapper.
#
# Copyright(C) 2016- Anssi Syrjäsalo (http://a.syrjasalo.com)
# Licensed under GNU Lesser General Public License v3 (LGPL-3.0).

# shim for running coding agents in a lima VM

: "${NAME:="default"}"
: "${TEMPLATE:="debian"}"
: "${AGENT:="pi"}"
: "${FW:=GITHUB_TOKEN,CONTEXT7_API_KEY,EXA_API_KEY}"

case "$AGENT" in
pi) FW="$FW,PI_RUN_CODE_UNSANDBOXED,MINIMAX_API_KEY,ZAI_API_KEY" ;;
opencode) FW="$FW,OPENCODE_API_KEY,OPENCODE_FORCE_FULL_READ_ACTIVE" ;;
claude) FW="$FW,ANTHROPIC_API_KEY" ;;
codex) FW="$FW,OPENAI_API_KEY" ;;
esac

if [ "$(uname -s)" = 'Darwin' ]; then
  if ! command -v limactl >/dev/null; then
    echo "Error: limactl not found on macOS, cannot start Linux VM for pi."
    exit 127
  fi
  box_cwd=$(pwd -P)
  lima_yaml="$HOME/.config/configent/lima/$TEMPLATE.yaml"

  # Sync provider credentials from host into the Linux guest via limactl cp
  box_sync_agent_auth_into_vm() {
    guest_home=$(limactl shell --tty=false "$NAME" -- printenv HOME) ||
      return 0
    [ -n "$guest_home" ] || return 0

    limactl shell --tty=false "$NAME" -- mkdir -p \
      "${guest_home}/.ssh" \
      "${guest_home}/.pi/agent" \
      "${guest_home}/.local/share/opencode" \
      "${guest_home}/.codex" ||
      return 0

    # SSH: known_hosts
    [ -f "$HOME/.ssh/known_hosts" ] &&
      limactl cp "$HOME/.ssh/known_hosts" \
        "$NAME:${guest_home}/.ssh/known_hosts"

    # Pi Coding Agent
    [ -f "$HOME/.pi/agent/auth.json" ] &&
      limactl cp "$HOME/.pi/agent/auth.json" \
        "$NAME:${guest_home}/.pi/agent/auth.json"

    # OpenCode
    [ -f "$HOME/.local/share/opencode/auth.json" ] &&
      limactl cp "$HOME/.local/share/opencode/auth.json" \
        "$NAME:${guest_home}/.local/share/opencode/auth.json"
    [ -f "$HOME/.local/share/opencode/mcp-auth.json" ] &&
      limactl cp "$HOME/.local/share/opencode/mcp-auth.json" \
        "$NAME:${guest_home}/.local/share/opencode/mcp-auth.json"

    # Codex CLI
    [ -f "$HOME/.codex/auth.json" ] &&
      limactl cp "$HOME/.codex/auth.json" \
        "$NAME:${guest_home}/.codex/auth.json"
  }

  # remove $box_cwd so that the subsequent --mount does not create a duplicate
  box_remove_cwd_mount() {
    lima_instance_yaml="$HOME/.lima/$NAME/lima.yaml"
    grep -qF "location: ${box_cwd}" "$lima_instance_yaml" 2>/dev/null || return 0
    awk -v path="${box_cwd}" '
      /^- location: / && substr($0, 13) == path { skip=1; next }
      skip && /^  / { next }
      { skip=0; print }
    ' "$lima_instance_yaml" >"${lima_instance_yaml}.tmp" &&
      mv "${lima_instance_yaml}.tmp" "$lima_instance_yaml"
  }

  # --mount-only replaces the full mount list; keep template dirs + cwd rw
  box_start_mount_only() {
    box_remove_cwd_mount
    limactl start --name "$NAME" --tty=false \
      --mount "${box_cwd}:w"
  }
  box_create_instance() {
    net="$1"
    limactl start --name "$NAME" --tty=false "$lima_yaml" \
      --vm-type=vz \
      --network="$net" \
      --rosetta \
      --mount "${box_cwd}:w" \
      --set=".env.MISE_GITHUB_TOKEN = \"$MISE_GITHUB_TOKEN\"" \
      --set=".env.EMAIL = \"$EMAIL\"" \
      --set=".env.GIT_AUTHOR_NAME = \"$GIT_AUTHOR_NAME\"" \
      --set=".env.GIT_COMMITTER_NAME = \"$GIT_COMMITTER_NAME\"" ||
      box_start_mount_only
  }

  # Sync mounts whenever the instance exists (also when already running)
  if limactl list -q 2>/dev/null | grep -qx "$NAME"; then
    box_start_mount_only
  elif [ -x "/opt/socket_vmnet/bin/socket_vmnet" ]; then
    box_create_instance lima:bridged
  else
    box_create_instance vzNAT
  fi

  export LIMA_SHELLENV_BLOCK='*'

  term='TERM,COLORTERM,TERM_PROGRAM,TERM_PROGRAM_VERSION,NO_COLOR,FORCE_COLOR'
  git='EMAIL,GIT_AUTHOR_NAME,GIT_COMMITTER_NAME'
  if [ -n "${LIMA_SHELLENV_ALLOW-}" ]; then
    export LIMA_SHELLENV_ALLOW="$FW,$term,$git,$LIMA_SHELLENV_ALLOW"
  else
    export LIMA_SHELLENV_ALLOW="$FW,$term,$git"
  fi

  box_sync_agent_auth_into_vm

  limactl shell \
    --preserve-env \
    --workdir "$box_cwd" \
    "$NAME" \
    /bin/bash -ic 'exec '"$AGENT"' "$@"' _ "$@"
else
  "$AGENT" "$@"
fi
