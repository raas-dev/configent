#!/bin/sh

# configent (https://github.com/raas-dev/configent)
# One command automated macOS/Linux laptop/VM/container bootstrapper.
#
# Copyright(C) 2016- Anssi Syrjäsalo (http://a.syrjasalo.com)
# Licensed under GNU Lesser General Public License v3 (LGPL-3.0).

# sb: run coding agents in OS-level sandbox

_usage() {
  echo "Usage: sb [-p|--proxy] [-v|--verbose] <agent> [args...]" >&2
  echo "" >&2
  echo "Agents:" >&2
  echo "  pi        Pi Coding Agent" >&2
  echo "  omp       oh-my-pi" >&2
  echo "  opencode  OpenCode" >&2
  echo "  claude    Claude Code CLI" >&2
  echo "  codex     OpenAI Codex CLI" >&2
  echo "" >&2
  echo "Options:" >&2
  echo "  -p, --proxy       Use nono run (proxy mode) instead of nono wrap" >&2
  echo "  -v, --verbose     Show nono diagnostics after agent finished" >&2
  exit 1
}

[ $# -eq 0 ] && _usage
PROXY=0
VERBOSE=0
while [ $# -gt 0 ]; do
  case "$1" in
  -p | --proxy)
    PROXY=1
    shift
    ;;
  -v | --verbose)
    VERBOSE=1
    shift
    ;;
  -h | --help)
    _usage
    ;;
  --)
    shift
    break
    ;;
  -*)
    echo "Error: unknown option: $1" >&2
    _usage
    ;;
  *)
    break
    ;;
  esac
done
[ $# -eq 0 ] && _usage
RUN="$1"
shift
PROFILE="${PROFILE:-$RUN}"
if [ "$(uname)" = "Darwin" ]; then
  case "$PROFILE" in
  claude | opencode | pi | omp | codex) PROFILE="${PROFILE}-macos" ;;
  esac
fi
[ "$PROXY" -eq 1 ] && PROFILE="${PROFILE}-proxy"
NONO_CMD="wrap"
[ "$PROXY" -eq 1 ] && NONO_CMD="run"

# Suppress diagnostic footer unless -v|--verbose.
NONO_DIAG_FLAG="--no-diagnostics"
[ "$VERBOSE" -eq 1 ] && NONO_DIAG_FLAG=""

if ! command -v nono >/dev/null 2>&1; then
  echo "Error: nono not found." >&2
  exit 127
fi

# Restore tty if TUI agent (opencode/claude/codex) exits without disabling
# mouse tracking, focus/theme reports, etc. Intentionally omit ?1049l
# (exit alt screen) to avoid main-buffer restore / perceived clear.
_restore_tty() {
  [ -t 1 ] || return 0
  stty sane 2>/dev/null
  printf '\033[?1000l\033[?1002l\033[?1003l\033[?1004l\033[?1006l\033[?2004l\033[?997l\033[?2031l\033[?25h'
}
trap _restore_tty EXIT INT TERM HUP

# Pi's bun-compiled binary calls `npm root -g` to locate extensions, which fails
# in nono sandbox. Run via node using the npm-installed cli.js instead.
if [ "$RUN" = "pi" ] && command -v mise >/dev/null 2>&1; then
  _node_root="$(mise where node 2>/dev/null)"
  # shellcheck disable=SC2086
  nono $NONO_CMD --profile "$PROFILE" $NONO_DIAG_FLAG \
    "$_node_root/bin/node" \
    "$_node_root/lib/node_modules/@earendil-works/pi-coding-agent/dist/cli.js" \
    "$@"
else
  # shellcheck disable=SC2086
  nono $NONO_CMD --profile "$PROFILE" $NONO_DIAG_FLAG "$RUN" "$@"
fi
