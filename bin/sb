#!/bin/sh

# configent (https://github.com/raas-dev/configent)
# One command automated macOS/Linux laptop/VM/container bootstrapper.
#
# Copyright(C) 2016- Anssi Syrjäsalo (http://a.syrjasalo.com)
# Licensed under GNU Lesser General Public License v3 (LGPL-3.0).

# sb: run coding agents in nono sandbox

_usage() {
  echo "Usage: sb [-i] <agent> [args...]" >&2
  echo "Agents: pi, omp, opencode, claude, codex" >&2
  exit 1
}

[ $# -eq 0 ] && _usage
INTERACTIVE=0
while [ $# -gt 0 ]; do
  case "$1" in
  -i)
    INTERACTIVE=1
    shift
    ;;
  -h | --help)
    _usage
    ;;
  --)
    shift
    break
    ;;
  -*)
    echo "Error: unknown option: $1" >&2
    _usage
    ;;
  *)
    break
    ;;
  esac
done
[ $# -eq 0 ] && _usage
RUN="$1"
shift
PROFILE="${PROFILE:-$RUN}"

if ! command -v nono >/dev/null 2>&1; then
  echo "Error: nono not found." >&2
  exit 127
fi

# Non-interactive default; use -i for login shell startup.
if [ "$INTERACTIVE" -eq 1 ]; then
  exec nono run --profile "$PROFILE" \
    "${SHELL:-/bin/sh}" -ilc 'exec "$@"' sh "$RUN" "$@"
else
  exec nono run --profile "$PROFILE" "$RUN" "$@"
fi
