#!/bin/sh

# configent (https://github.com/raas-dev/configent)
# One command automated macOS/Linux laptop/VM/container bootstrapper.
#
# Copyright(C) 2016- Anssi Syrjäsalo (http://a.syrjasalo.com)
# Licensed under GNU Lesser General Public License v3 (LGPL-3.0).

# sb: run coding agents in nono sandbox

_usage() {
  echo "Usage: sb [-i|--init-shell] <agent> [args...]" >&2
  echo "Agents: pi, omp, opencode, claude, codex" >&2
  exit 1
}

[ $# -eq 0 ] && _usage
INIT_SHELL=0
while [ $# -gt 0 ]; do
  case "$1" in
  -i | --init-shell)
    INIT_SHELL=1
    shift
    ;;
  -h | --help)
    _usage
    ;;
  --)
    shift
    break
    ;;
  -*)
    echo "Error: unknown option: $1" >&2
    _usage
    ;;
  *)
    break
    ;;
  esac
done
[ $# -eq 0 ] && _usage
RUN="$1"
shift
PROFILE="${PROFILE:-$RUN}"

if ! command -v nono >/dev/null 2>&1; then
  echo "Error: nono not found." >&2
  exit 127
fi

# Restore tty if TUI agent (opencode/claude/codex) exits without disabling
# alt-screen, mouse tracking, focus/theme reports, etc.
_restore_tty() {
  [ -t 1 ] || return 0
  stty sane 2>/dev/null
  printf '\033[?1000l\033[?1002l\033[?1003l\033[?1004l\033[?1006l\033[?2004l\033[?997l\033[?2031l\033[?1049l\033[?25h'
}
trap _restore_tty EXIT INT TERM HUP

# Non-interactive default; use -i for login shell startup.
if [ "$INIT_SHELL" -eq 1 ]; then
  nono run --profile "$PROFILE" \
    "${SHELL:-/bin/sh}" -ilc 'exec "$@"' sh "$RUN" "$@"
else
  nono run --profile "$PROFILE" "$RUN" "$@"
fi
