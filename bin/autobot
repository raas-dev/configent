#!/bin/sh

# Split on lines that start with $ (after optional leading │). Each block is one
# command until the next $. We take the last non-empty block, but skip the
# current invocation: "autobot …" and optional AUTOBOT_ALIASES.
# Trailing bare "$" blocks are skipped. Then tail-cap with AUTOBOT_LINES.

set -e

window=${AUTOBOT_WINDOW:-120}
lines=${AUTOBOT_LINES:-24}
# How many recent $-blocks to include (newest = focus). 1 = only last command (legacy).
ctx_blocks=${AUTOBOT_CONTEXT_BLOCKS:-3}
# Max lines per older block; primary uses AUTOBOT_LINES.
prior_lines=${AUTOBOT_PRIOR_LINES:-16}
# First-word aliases for this script (default ? — see dotfiles/.aliases). Empty to disable.
aliases=${AUTOBOT_ALIASES-?}
# omp --model (override with -m/--model).
model=${AUTOBOT_MODEL:-zai/glm-5-turbo}

# stdin: full pane/body; stdout: XML-ish sections — earlier blocks capped, last block primary
autobot_last_cmd() {
  tail -n "$window" | awk -v aliases="$aliases" \
    -v ctxblocks="$ctx_blocks" -v prior_lines="$prior_lines" -v primary_lines="$lines" '
    function should_skip(s,   parts, nf, first, al, na, j) {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
      if (length(s) < 1) return 0
      if (s ~ /^autobot([[:space:]]|$)/) return 1
      if (length(aliases) < 1) return 0
      nf = split(s, parts, /[[:space:]]+/)
      first = parts[1]
      na = split(aliases, al, /[[:space:]]+/)
      for (j = 1; j <= na; j++) {
        if (al[j] != "" && first == al[j]) return 1
      }
      return 0
    }
    function tail_lines(s, max,   a, nlines, i, out) {
      if (max < 1 || length(s) < 1) return s
      nlines = split(s, a, /\n/)
      if (nlines <= max) return s
      out = a[nlines - max + 1]
      for (i = nlines - max + 2; i <= nlines; i++) out = out "\n" a[i]
      return out
    }
    {
      raw = $0
      all[NR] = raw
      line = raw
      if (line ~ /^[[:space:]]*│/) sub(/^[[:space:]]*│[[:space:]]*/, "", line)

      if (line ~ /^\$/) {
        n++
        rest = line
        sub(/^\$/, "", rest)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", rest)
        hascmd[n] = (length(rest) > 0)
        cmd[n] = rest
        seg[n] = raw "\n"
        next
      }
      if (n > 0) seg[n] = seg[n] raw "\n"
    }
    END {
      if (n < 1) {
        max = primary_lines
        from = (NR > max ? NR - max + 1 : 1)
        for (i = from; i <= NR; i++) print all[i]
        exit
      }
      P = 0
      for (i = n; i >= 1; i--) {
        if (!hascmd[i]) continue
        if (should_skip(cmd[i])) continue
        P++
        pick_idx[P] = i
        if (P >= ctxblocks) break
      }
      if (P < 1) {
        max = primary_lines
        from = (NR > max ? NR - max + 1 : 1)
        for (i = from; i <= NR; i++) print all[i]
        exit
      }
      if (ctxblocks < 2 || P < 2) {
        printf "%s", tail_lines(seg[pick_idx[1]], primary_lines)
        exit
      }
      print "<earlier_terminal_context>"
      for (p = P; p >= 2; p--) {
        printf "%s", tail_lines(seg[pick_idx[p]], prior_lines)
        if (p > 2) print "\n---\n"
      }
      print "</earlier_terminal_context>"
      print "<terminal_output>"
      printf "%s", tail_lines(seg[pick_idx[1]], primary_lines)
      print "</terminal_output>"
    }
  '
}

# stdout: first readable shell history path, or nothing.
autobot_find_history_file() {
  if [ -n "${HISTFILE:-}" ] && [ -r "$HISTFILE" ]; then
    printf '%s' "$HISTFILE"
    return 0
  fi
  if [ -r "${ZDOTDIR:-$HOME}/.zsh_history" ]; then
    printf '%s' "${ZDOTDIR:-$HOME}/.zsh_history"
    return 0
  fi
  if [ -r "$HOME/.zsh_history" ]; then
    printf '%s' "$HOME/.zsh_history"
    return 0
  fi
  if [ -r "$HOME/.bash_history" ]; then
    printf '%s' "$HOME/.bash_history"
    return 0
  fi
  return 1
}

# stdout: previous shell command; stderr empty; exit 1 if none found.
# Uses AUTOBOT_PREVIOUS_CMD when set (non-empty), else tails a history file.
autobot_get_previous_cmd() {
  if [ -n "$AUTOBOT_PREVIOUS_CMD" ]; then
    printf '%s\n' "$AUTOBOT_PREVIOUS_CMD"
    return 0
  fi
  hist=$(autobot_find_history_file) || true
  if [ -z "$hist" ]; then
    echo "autobot: no readable history file (set HISTFILE or AUTOBOT_PREVIOUS_CMD)" >&2
    return 1
  fi
  tail -n "${AUTOBOT_HIST_TAIL:-$window}" "$hist" | awk -v aliases="$aliases" '
    function trim(s) {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
      gsub(/\r$/, "", s)
      return s
    }
    function first_words(cmd, parts, nf) {
      nf = split(cmd, parts, /[[:space:]]+/)
      return nf
    }
    function skip_cmd(cmd,   p, nf, first, al, na, j) {
      cmd = trim(cmd)
      if (length(cmd) < 1) return 1
      if (cmd ~ /^#/) return 1
      nf = first_words(cmd, p)
      first = p[1]
      if (first == "autobot") return 1
      if (length(aliases) > 0) {
        na = split(aliases, al, /[[:space:]]+/)
        for (j = 1; j <= na; j++) {
          if (al[j] != "" && first == al[j]) return 1
        }
      }
      return 0
    }
    function parse_line(raw,   line, cmd) {
      line = raw
      gsub(/\r$/, "", line)
      if (line ~ /^: [0-9]+:[0-9];/) {
        sub(/^: [0-9]+:[0-9];/, "", line)
        return line
      }
      if (line ~ /^#[0-9]+$/) return ""
      return line
    }
    { lines[++n] = $0 }
    END {
      for (i = n; i >= 1; i--) {
        cmd = parse_line(lines[i])
        if (skip_cmd(cmd)) continue
        printf "%s\n", trim(cmd)
        exit 0
      }
      exit 1
    }
  '
}

usage() {
  echo "Usage: autobot [-d|--dry-run] [-m|--model ID] [-c|--rerun [command args...]]" >&2
  echo "  -d, --dry-run   Print captured terminal output on stdout; do not run pi." >&2
  echo "  -m, --model     omp model id (default: minimax/MiniMax-M2.7; env AUTOBOT_MODEL)." >&2
  echo "  -c, --rerun     Re-run a command; everything after it is command + args (the tail of argv)." >&2
  echo "                  Bare -c (nothing after) → history / AUTOBOT_PREVIOUS_CMD." >&2
  echo "                  Use -c -- cmd ... if cmd starts with -." >&2
  echo "                  Runs via interactive \$SHELL (bash/zsh/ksh/mksh/fish) so shell aliases apply." >&2
  echo "  (default)       Explain capture, plan a fix (no actions), ask; apply only after you confirm." >&2
  echo "Env: AUTOBOT_LINES (primary block), AUTOBOT_CONTEXT_BLOCKS (recent \$ blocks, default 3)," >&2
  echo "     AUTOBOT_PRIOR_LINES (older blocks), AUTOBOT_WINDOW, AUTOBOT_ALIASES," >&2
  echo "     AUTOBOT_MODEL, AUTOBOT_PREVIOUS_CMD (default for bare -c)," >&2
  echo "     AUTOBOT_HIST_TAIL (history tail size; default same as AUTOBOT_WINDOW)," >&2
  echo "     AUTOBOT_TMUX_START (tmux capture-pane -S; default matches AUTOBOT_WINDOW)," >&2
  echo "     AUTOBOT_SHELL_PID (Cursor: force terminal file match when PPID chain fails)." >&2
}

# Globals: _dry_run, _rerun, _prev_cmd; model (default set above)
autobot_parse_args() {
  _dry_run=0
  _rerun=0
  _prev_cmd=

  while [ $# -gt 0 ]; do
    case $1 in
    -d | --dry-run)
      _dry_run=1
      shift
      ;;
    -m | --model)
      if [ $# -lt 2 ]; then
        echo "autobot: $1 needs a value" >&2
        exit 1
      fi
      model=$2
      shift 2
      ;;
    -h | --help)
      usage
      exit 0
      ;;
    -c | --rerun)
      _rerun=1
      shift
      if [ $# -eq 0 ]; then
        _prev_cmd=$(autobot_get_previous_cmd) || exit 1
      elif [ "$1" = "--" ]; then
        shift
        if [ $# -eq 0 ]; then
          echo "autobot: --rerun / -c -- needs a command" >&2
          exit 1
        fi
        _prev_cmd=$*
        set --
      else
        _prev_cmd=$*
        set --
      fi
      break
      ;;
    *)
      echo "autobot: unexpected arguments (use -m/-d before -c/--rerun if needed): $*" >&2
      exit 1
      ;;
    esac
  done
}

# Uses: _prev_cmd, _dry_run. stdout: synthetic pane text for autobot_last_cmd.
autobot_build_rerun_synthetic() {
  if [ "$_dry_run" = 1 ]; then
    printf '%s\n' "\$ $_prev_cmd
(autobot: dry-run, command not executed)"
    return
  fi
  run_shell=${SHELL:-/bin/sh}
  shell_base=${run_shell##*/}
  set +e
  case $shell_base in
  bash | zsh | ksh | mksh)
    run_out=$(
      cd "$PWD" && AUTOBOT_RERUN_CMD="$_prev_cmd" "$run_shell" -ic "eval \"\$AUTOBOT_RERUN_CMD\"" </dev/null 2>&1
    )
    ;;
  fish)
    run_out=$(
      cd "$PWD" && AUTOBOT_RERUN_CMD="$_prev_cmd" fish -ic "eval \$AUTOBOT_RERUN_CMD" </dev/null 2>&1
    )
    ;;
  *)
    tmp=$(mktemp "${TMPDIR:-/tmp}/autobot.XXXXXX") || exit 1
    printf '%s\n' "$_prev_cmd" >"$tmp"
    run_out=$(cd "$PWD" && "$run_shell" "$tmp" </dev/null 2>&1)
    rm -f "$tmp"
    ;;
  esac
  run_rc=$?
  set -e
  printf '%s\n' "\$ $_prev_cmd
$run_out
(exit status: $run_rc)"
}

# stdout: path to newest Cursor terminal file for shell pid, or empty.
autobot_find_cursor_terminal_file() {
  shell_pid=$1
  find "$HOME/.cursor/projects/" -maxdepth 3 -name "*.txt" -path "*/terminals/*" 2>/dev/null | while read -r f; do
    if grep -q "^pid: ${shell_pid}$" "$f" 2>/dev/null; then
      mtime=$(stat --format '%Y' "$f" 2>/dev/null) || mtime=$(stat -f %m "$f" 2>/dev/null) || mtime=0
      printf '%s %s\n' "$mtime" "$f"
    fi
  done | sort -rn | head -1 | cut -d' ' -f2-
}

# stdout: parent pid of $1, or empty.
autobot_ps_ppid() {
  ps -p "$1" -o ppid= 2>/dev/null | awk '{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $1); print}'
}

# stdout: newest terminal snapshot whose header cwd: matches $PWD, or empty.
autobot_find_cursor_terminal_by_cwd() {
  find "$HOME/.cursor/projects/" -maxdepth 3 -name "*.txt" -path "*/terminals/*" 2>/dev/null | while read -r f; do
    cw=$(grep -m1 '^cwd: ' "$f" 2>/dev/null | sed 's/^cwd:[[:space:]]*//; s/[[:space:]]+$//')
    [ -z "$cw" ] && continue
    [ "$cw" = "$PWD" ] || continue
    mtime=$(stat --format '%Y' "$f" 2>/dev/null) || mtime=$(stat -f %m "$f" 2>/dev/null) || mtime=0
    printf '%s %s\n' "$mtime" "$f"
  done | sort -rn | head -1 | cut -d' ' -f2-
}

# stdout: path to Cursor terminal file for this session (real pane history).
# Order: AUTOBOT_SHELL_PID, walk PPID chain (make/wrap → real shell), else cwd match in $PWD.
autobot_resolve_cursor_terminal_file() {
  if [ -n "${AUTOBOT_SHELL_PID:-}" ]; then
    tf=$(autobot_find_cursor_terminal_file "$AUTOBOT_SHELL_PID")
    if [ -n "$tf" ]; then
      printf '%s\n' "$tf"
      return 0
    fi
  fi
  p=$PPID
  _walk_i=0
  while [ "$_walk_i" -lt 12 ]; do
    case $p in '' | *[!0-9]*) break ;; esac
    if [ "$p" -lt 2 ] 2>/dev/null; then
      break
    fi
    tf=$(autobot_find_cursor_terminal_file "$p")
    if [ -n "$tf" ]; then
      printf '%s\n' "$tf"
      return 0
    fi
    p=$(autobot_ps_ppid "$p")
    _walk_i=$((_walk_i + 1))
  done
  tf=$(autobot_find_cursor_terminal_by_cwd)
  if [ -n "$tf" ]; then
    echo "autobot: Cursor terminal matched by cwd (set AUTOBOT_SHELL_PID for exact shell pid)" >&2
    printf '%s\n' "$tf"
    return 0
  fi
  return 1
}

# stdout: body between 2nd and 3rd "---" in Cursor terminal snapshot.
autobot_cursor_terminal_body() {
  awk '
    /^---$/ { n++; if (n == 2) { capture = 1; next } if (n == 3) { capture = 0 } next }
    capture { print }
  ' "$1"
}

# True (exit 0) only when TMUX is set and this process can talk to that tmux client.
# So we prefer tmux capture when actually inside tmux; stray TMUX in env still allows Cursor fallback.
autobot_in_tmux() {
  [ -n "${TMUX:-}" ] && tmux display-message -p '#{pane_id}' >/dev/null 2>&1
}

# Globals: _rerun, _dry_run, _prev_cmd. Sets: _output (via command substitution caller).
# Capture order: synthetic re-run → tmux pane (if in tmux) → Cursor snapshot — never Cursor when tmux works.
autobot_capture_output() {
  if [ "$_rerun" = 1 ]; then
    if [ -z "$_prev_cmd" ]; then
      echo "autobot: no command to re-run (set AUTOBOT_PREVIOUS_CMD)" >&2
      exit 1
    fi
    _output=$(autobot_build_rerun_synthetic | autobot_last_cmd)
    return
  fi

  if autobot_in_tmux; then
    # capture-pane -S: negative = lines from bottom; default -AUTOBOT_WINDOW unless AUTOBOT_TMUX_START set.
    _output=$(tmux capture-pane -p -S "${AUTOBOT_TMUX_START:--$window}" | autobot_last_cmd)
    return
  fi

  if [ -d "$HOME/.cursor/projects" ]; then
    terminal_file=$(autobot_resolve_cursor_terminal_file) || terminal_file=
    if [ -z "$terminal_file" ]; then
      echo "autobot: no Cursor terminal file (tried PPID chain + cwd: $PWD). Set AUTOBOT_SHELL_PID to your shell pid." >&2
      exit 1
    fi
    _output=$(autobot_cursor_terminal_body "$terminal_file" | autobot_last_cmd)
    return
  fi

  echo "autobot: not in tmux or Cursor (no ~/.cursor/projects); use -c to capture from a re-run command" >&2
  exit 1
}

autobot_emit_dry_run() {
  echo "autobot: dry-run (agent not invoked)" >&2
  if [ "$_rerun" = 1 ]; then
    echo "autobot: capture source: would re-run: $_prev_cmd (not executed in dry-run)" >&2
  fi
  echo "autobot: would use default explain/fix flow (new agent session)" >&2
  echo "autobot: --- captured terminal output (stdout) ---" >&2
  printf '%s\n' "$_output"
}

autobot_default_prompt_text() {
  cat <<'EOF'
The following is real terminal history from the user’s session: if they are in tmux, it is tmux capture-pane scrollback (preferred); otherwise, when available, the Cursor integrated-terminal snapshot (after the metadata header); with -c/--rerun, synthetic output from that re-run. It is the recent shell transcript the user was looking at—not a summary.

First, plan only: do NOT run terminal commands, edit files, or apply any fix yet.

**Scope the failure first — do not assume the last command is the one to fix.**
- Scan the **entire** capture: both `<earlier_terminal_context>` (older `$` blocks) **and** `<terminal_output>` (most recent). The user’s real failure may be in an earlier block while the last block is unrelated (e.g. they ran `ls`, `git status`, `cd`, a successful command, a pager, or noise after the breakage).
- Enumerate every distinct failure / error / suspicious anomaly you can identify across the capture (non-zero-looking exits, stack traces, `error:` / `fatal:` / `panic:` / `Traceback` / `command not found`, failing test output, build errors, lints, etc.). Skip clearly successful commands and pure informational output.
- Pick a single primary failure to fix **only if** one of these holds:
  - exactly one failure is present in the capture, **or**
  - the most recent `$` block (`<terminal_output>`) clearly contains a failure and no earlier block has an unresolved, more severe failure that looks like the user’s actual concern.
- Otherwise (multiple candidate failures, ambiguous which one the user cares about, or the last block is benign while earlier blocks broke) you are **unsure** — do not guess. Use **`ask`** (see below) to let the user pick which failure to fix before producing a diagnosis or fix plan. List each candidate with its `$` command and a short caveman tag of the error.

In your planning reply:
- Briefly characterize the capture: which `$` blocks ran, which succeeded, which failed; call out that the failure may not be the last command if that is the case.
- Lead with an **error/situation summary** in caveman style for the chosen (or candidate) failure(s): strip articles, filler, hedging, pleasantries; fragments OK; short synonyms where meaning unchanged; **technical terms, paths, and quoted stderr/log lines exactly** as in the capture; pattern `thing · broke · reason.` optional `next: …`; code or commands unchanged if shown. Technical substance stays; fluff dies.
- Short diagnosis (likely root cause) of the chosen failure, building from that summary. If unsure which failure → skip diagnosis until **`ask`** resolves the scope.
- **omp host tools only (`todo_write`, `ask`):** Todos and user choices **must** go through **omp’s** registered tools — the same mechanisms the UI renders as tool runs — **not** through free-form model output. Do **not** replace them with: markdown task lists, numbered “TODO:” sections, inline JSON payloads in assistant text, XML (`<invoke>`, `<parameter>`, etc.), fenced “tool_use” blocks, or pasted “pick A/B” questions. Those do **not** update omp; they are wrong.
- **`todo_write`:** Drive the investigation with **`todo_write`** (scope, narrowing, evidence, fix branches). Keep the list current until issue **and** solution path(s) are clear. When unsure which failure to fix, the first phase is scope-selection (one task per candidate failure). For apply-choice: **replace** open work with one task per candidate fix, or one yes/no task if there is a single main fix. Example payload shape (arguments to the tool, not prose): `{"ops":[{"op":"replace","phases":[{"name":"Plan","tasks":[{"content":"…","status":"in_progress"}]}]}]}`; use **`update`** / **`add_task`** / **`remove_task`** per schema; for **`update`**/**`remove_task`**, use task ids from the tool/UI state, do not invent ids.
- **`ask`:** After the final **`todo_write`**, call **`ask`**. If unsure which failure to fix, ask **which failure to fix** first, with one option per candidate (label each with the `$` command + caveman error tag) plus a free-form / “none of these” option; do not propose fixes yet. If a single failure is clear, ask which fix option(s) to apply. Do **not** ask the user to choose only in plain text; **`ask`** is required. Declining all remains allowed.
- Proposed commands and code changes as fenced blocks or bullet lists, clearly labeled as proposed — still no execution or patches; align proposals with the solution branches named in the final todos. Skip these entirely while still resolving scope via **`ask`**.
- Stop after that **`todo_write`** rewrite + **`ask`**; do not apply anything in the same turn as the plan.

Only after the user answers **`ask`** in favor of applying (for the chosen option(s)): carry out the plan, verify if reasonable, then one-line summary. If the **`ask`** was a scope-selection, the next turn re-plans the chosen failure (still no apply) and then asks again for the apply-choice.
EOF
}

# stdout: plain lines for <environment> (uses globals _rerun, TMUX, HOME, etc.)
autobot_environment_text() {
  os=$(uname -s)
  printf 'OS: %s  kernel: %s  arch: %s\n' "$os" "$(uname -r)" "$(uname -m)"
  case $os in
  Darwin)
    if command -v sw_vers >/dev/null 2>&1; then
      printf 'macOS: %s\n' "$(sw_vers -productVersion)"
    fi
    ;;
  Linux)
    if [ -r /etc/os-release ]; then
      pretty=$(awk -F= '/^PRETTY_NAME=/ {
        gsub(/^"|"$/, "", $2)
        print $2
        exit
      }' /etc/os-release)
      if [ -n "$pretty" ]; then
        printf 'Distro: %s\n' "$pretty"
      fi
    fi
    ;;
  esac
  printf 'Host: %s  User: %s\n' "$(uname -n)" "${USER:-unknown}"
  printf 'PWD: %s\n' "$PWD"
  printf 'TERM: %s\n' "${TERM:-unset}"
  if [ -n "${LANG:-}" ] || [ -n "${LC_ALL:-}" ]; then
    printf 'Locale: LANG=%s LC_ALL=%s\n' "${LANG:-unset}" "${LC_ALL:-unset}"
  fi
  printf 'Default login shell (SHELL): %s\n' "${SHELL:-unknown}"
  if [ -n "${ZSH_VERSION:-}" ]; then
    printf 'Invoking shell: zsh %s\n' "$ZSH_VERSION"
  elif [ -n "${BASH_VERSION:-}" ]; then
    printf 'Invoking shell: bash %s\n' "$BASH_VERSION"
  else
    printf 'Invoking shell: %s (autobot runs as POSIX sh)\n' "${0##*/}"
  fi
  if [ "$_rerun" = 1 ]; then
    printf 'Terminal capture: synthetic re-run via SHELL\n'
  elif autobot_in_tmux; then
    printf 'Terminal capture: tmux capture-pane\n'
  elif [ -d "$HOME/.cursor/projects" ]; then
    printf 'Terminal capture: Cursor IDE terminal snapshot\n'
  else
    printf 'Terminal capture: other\n'
  fi
}

autobot_parse_args "$@"
autobot_capture_output

if [ "$_dry_run" = 1 ]; then
  autobot_emit_dry_run
  exit 0
fi

_instructions=$(autobot_default_prompt_text)
_environment=$(autobot_environment_text)

_prompt="<instructions>
$_instructions
</instructions>

<terminal_capture>
$_output
</terminal_capture>

Context: <earlier_terminal_context> (when present) holds older \$-prompt blocks and <terminal_output> is the most recent block before autobot ran. The real failure the user wants fixed may live in **either** section — the last command is often unrelated noise (cd, ls, git status, a pager). Treat both sections as in-scope and follow the scoping rules in <instructions>: if multiple candidate failures exist or it is unclear which the user cares about, use the **ask** host tool to confirm before diagnosing or proposing a fix.

<environment>
$_environment
</environment>
"

omp \
  --allow-home \
  --no-extensions \
  --no-rules \
  --no-session \
  --no-skills \
  --no-title \
  --model "$model" \
  "$_prompt"
