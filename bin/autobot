#!/bin/sh

# Split on lines that start with $ (after optional leading │). Each block is one
# command until the next $. We take the last non-empty block, but skip the
# current invocation: "autobot …" and optional AUTOBOT_ALIASES.
# Trailing bare "$" blocks are skipped. Then tail-cap with AUTOBOT_LINES.

set -e

window=${AUTOBOT_WINDOW:-120}
lines=${AUTOBOT_LINES:-24}
# How many recent $-blocks to include (newest = focus). 1 = only last command (legacy).
ctxblocks=${AUTOBOT_CONTEXT_BLOCKS:-3}
# Max lines per older block; primary uses AUTOBOT_LINES.
prior_lines=${AUTOBOT_PRIOR_LINES:-16}
# First-word aliases for this script (default a — see dotfiles/.aliases). Empty to disable.
_ab_aliases=${AUTOBOT_ALIASES-a}

# stdin: full pane/body; stdout: XML-ish sections — earlier blocks capped, last block primary
autobot_last_cmd() {
  tail -n "$window" | awk -v aliases="$_ab_aliases" \
    -v ctxblocks="$ctxblocks" -v prior_lines="$prior_lines" -v primary_lines="$lines" '
    function should_skip(s,   parts, nf, first, al, na, j) {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
      if (length(s) < 1) return 0
      if (s ~ /^autobot([[:space:]]|$)/) return 1
      if (length(aliases) < 1) return 0
      nf = split(s, parts, /[[:space:]]+/)
      first = parts[1]
      na = split(aliases, al, /[[:space:]]+/)
      for (j = 1; j <= na; j++) {
        if (al[j] != "" && first == al[j]) return 1
      }
      return 0
    }
    function tail_lines(s, max,   a, nlines, i, out) {
      if (max < 1 || length(s) < 1) return s
      nlines = split(s, a, /\n/)
      if (nlines <= max) return s
      out = a[nlines - max + 1]
      for (i = nlines - max + 2; i <= nlines; i++) out = out "\n" a[i]
      return out
    }
    {
      raw = $0
      all[NR] = raw
      line = raw
      if (line ~ /^[[:space:]]*│/) sub(/^[[:space:]]*│[[:space:]]*/, "", line)

      if (line ~ /^\$/) {
        n++
        rest = line
        sub(/^\$/, "", rest)
        gsub(/^[[:space:]]+|[[:space:]]+$/, "", rest)
        hascmd[n] = (length(rest) > 0)
        cmd[n] = rest
        seg[n] = raw "\n"
        next
      }
      if (n > 0) seg[n] = seg[n] raw "\n"
    }
    END {
      if (n < 1) {
        max = primary_lines
        from = (NR > max ? NR - max + 1 : 1)
        for (i = from; i <= NR; i++) print all[i]
        exit
      }
      P = 0
      for (i = n; i >= 1; i--) {
        if (!hascmd[i]) continue
        if (should_skip(cmd[i])) continue
        P++
        pick_idx[P] = i
        if (P >= ctxblocks) break
      }
      if (P < 1) {
        max = primary_lines
        from = (NR > max ? NR - max + 1 : 1)
        for (i = from; i <= NR; i++) print all[i]
        exit
      }
      if (ctxblocks < 2 || P < 2) {
        printf "%s", tail_lines(seg[pick_idx[1]], primary_lines)
        exit
      }
      print "<earlier_terminal_context>"
      for (p = P; p >= 2; p--) {
        printf "%s", tail_lines(seg[pick_idx[p]], prior_lines)
        if (p > 2) print "\n---\n"
      }
      print "</earlier_terminal_context>"
      print "<terminal_output>"
      printf "%s", tail_lines(seg[pick_idx[1]], primary_lines)
      print "</terminal_output>"
    }
  '
}

# stdout: previous shell command; stderr empty; exit 1 if none found.
# Uses AUTOBOT_PREVIOUS_CMD when set (non-empty), else tails a history file.
autobot_get_previous_cmd() {
  if [ -n "$AUTOBOT_PREVIOUS_CMD" ]; then
    printf '%s\n' "$AUTOBOT_PREVIOUS_CMD"
    return 0
  fi
  hist=
  if [ -n "${HISTFILE:-}" ] && [ -r "$HISTFILE" ]; then
    hist=$HISTFILE
  elif [ -r "${ZDOTDIR:-$HOME}/.zsh_history" ]; then
    hist="${ZDOTDIR:-$HOME}/.zsh_history"
  elif [ -r "$HOME/.zsh_history" ]; then
    hist=$HOME/.zsh_history
  elif [ -r "$HOME/.bash_history" ]; then
    hist=$HOME/.bash_history
  fi
  if [ -z "$hist" ]; then
    echo "autobot: no readable history file (set HISTFILE or AUTOBOT_PREVIOUS_CMD)" >&2
    return 1
  fi
  tail -n "${AUTOBOT_HIST_TAIL:-120}" "$hist" | awk -v aliases="$_ab_aliases" '
    function trim(s) {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
      gsub(/\r$/, "", s)
      return s
    }
    function first_words(cmd, parts, nf) {
      nf = split(cmd, parts, /[[:space:]]+/)
      return nf
    }
    function skip_cmd(cmd,   p, nf, first, al, na, j) {
      cmd = trim(cmd)
      if (length(cmd) < 1) return 1
      if (cmd ~ /^#/) return 1
      nf = first_words(cmd, p)
      first = p[1]
      if (first == "autobot") return 1
      if (length(aliases) > 0) {
        na = split(aliases, al, /[[:space:]]+/)
        for (j = 1; j <= na; j++) {
          if (al[j] != "" && first == al[j]) return 1
        }
      }
      return 0
    }
    function parse_line(raw,   line, cmd) {
      line = raw
      gsub(/\r$/, "", line)
      if (line ~ /^: [0-9]+:[0-9];/) {
        sub(/^: [0-9]+:[0-9];/, "", line)
        return line
      }
      if (line ~ /^#[0-9]+$/) return ""
      return line
    }
    { lines[++n] = $0 }
    END {
      for (i = n; i >= 1; i--) {
        cmd = parse_line(lines[i])
        if (skip_cmd(cmd)) continue
        printf "%s\n", trim(cmd)
        exit 0
      }
      exit 1
    }
  '
}

usage() {
  echo "Usage: autobot [-d|--dry-run] [-c|--rerun [command args...]]" >&2
  echo "  -d, --dry-run   Print captured terminal output on stdout; do not run pi." >&2
  echo "  -c, --rerun     Re-run a command; everything after it is command + args (the tail of argv)." >&2
  echo "                  Bare -c (nothing after) → history / AUTOBOT_PREVIOUS_CMD." >&2
  echo "                  Use -c -- cmd ... if cmd starts with -." >&2
  echo "                  Runs via interactive \$SHELL (bash/zsh/ksh/mksh/fish) so shell aliases apply." >&2
  echo "  (default)       Explain capture, plan a fix (no actions), ask; apply only after you confirm." >&2
  echo "Env: AUTOBOT_LINES (primary block), AUTOBOT_CONTEXT_BLOCKS (recent \$ blocks, default 3)," >&2
  echo "     AUTOBOT_PRIOR_LINES (older blocks), AUTOBOT_WINDOW, AUTOBOT_ALIASES," >&2
  echo "     AUTOBOT_PREVIOUS_CMD (default for bare -c), AUTOBOT_HIST_TAIL (history tail size, default 120)." >&2
}

dry_run=0
rerun=0
prev_cmd=

while [ $# -gt 0 ]; do
  case $1 in
  -d | --dry-run)
    dry_run=1
    shift
    ;;
  -h | --help)
    usage
    exit 0
    ;;
  -c | --rerun)
    rerun=1
    shift
    if [ $# -eq 0 ]; then
      prev_cmd=$(autobot_get_previous_cmd) || exit 1
    elif [ "$1" = "--" ]; then
      shift
      if [ $# -eq 0 ]; then
        echo "autobot: --rerun / -c -- needs a command" >&2
        exit 1
      fi
      prev_cmd=$*
      set --
    else
      prev_cmd=$*
      set --
    fi
    break
    ;;
  *)
    echo "autobot: unexpected arguments (use -c/--rerun before command, -d first if needed): $*" >&2
    exit 1
    ;;
  esac
done

if [ "$rerun" = 1 ]; then
  if [ -z "$prev_cmd" ]; then
    echo "autobot: no command to re-run (set AUTOBOT_PREVIOUS_CMD)" >&2
    exit 1
  fi
  if [ "$dry_run" = 1 ]; then
    synthetic="\$ $prev_cmd
(autobot: dry-run, command not executed)"
  else
    run_shell=${SHELL:-/bin/sh}
    _ab_sh_base=${run_shell##*/}
    set +e
    case $_ab_sh_base in
    bash | zsh | ksh | mksh)
      # Interactive -c + eval: loads rc files and expands aliases (bash does not expand
      # aliases in -i script files). AUTOBOT_RERUN_CMD holds the exact line to run.
      run_out=$(
        cd "$PWD" && AUTOBOT_RERUN_CMD="$prev_cmd" "$run_shell" -ic "eval \"\$AUTOBOT_RERUN_CMD\"" </dev/null 2>&1
      )
      ;;
    fish)
      run_out=$(
        cd "$PWD" && AUTOBOT_RERUN_CMD="$prev_cmd" fish -ic "eval \$AUTOBOT_RERUN_CMD" </dev/null 2>&1
      )
      ;;
    *)
      tmp=$(mktemp "${TMPDIR:-/tmp}/autobot.XXXXXX") || exit 1
      printf '%s\n' "$prev_cmd" >"$tmp"
      run_out=$(cd "$PWD" && "$run_shell" "$tmp" </dev/null 2>&1)
      rm -f "$tmp"
      ;;
    esac
    run_rc=$?
    set -e
    synthetic="\$ $prev_cmd
$run_out
(exit status: $run_rc)"
  fi
  output=$(printf '%s\n' "$synthetic" | autobot_last_cmd)
elif [ -n "$TMUX" ]; then
  pane=$(tmux capture-pane -p -S -200)
  output=$(printf '%s\n' "$pane" | autobot_last_cmd)
elif [ -d "$HOME/.cursor/projects" ]; then
  shell_pid=$PPID
  terminal_file=$(find "$HOME/.cursor/projects/" -maxdepth 3 -name "*.txt" -path "*/terminals/*" 2>/dev/null | while read -r f; do
    if grep -q "^pid: ${shell_pid}$" "$f" 2>/dev/null; then
      _ts=$(stat --format '%Y' "$f" 2>/dev/null) || _ts=$(stat -f %m "$f" 2>/dev/null) || _ts=0
      printf '%s %s\n' "$_ts" "$f"
    fi
  done | sort -rn | head -1 | cut -d' ' -f2-)
  if [ -z "$terminal_file" ]; then
    echo "autobot: no Cursor terminal file found for shell pid ${shell_pid}" >&2
    exit 1
  fi
  body=$(awk '
    /^---$/ { n++; if (n == 2) { capture = 1; next } if (n == 3) { capture = 0 } next }
    capture { print }
  ' "$terminal_file")
  output=$(printf '%s\n' "$body" | autobot_last_cmd)
else
  echo "autobot: not in tmux or Cursor (no ~/.cursor/projects); use -c to capture from a re-run command" >&2
  exit 1
fi

if [ "$dry_run" = 1 ]; then
  echo "autobot: dry-run (pi not invoked)" >&2
  if [ "$rerun" = 1 ]; then
    echo "autobot: capture source: would re-run: $prev_cmd (not executed in dry-run)" >&2
  fi
  echo "autobot: would use default explain/fix flow (new pi session)" >&2
  echo "autobot: --- captured terminal output (stdout) ---" >&2
  printf '%s\n' "$output"
  exit 0
fi

autobot_default_prompt=$(
  cat <<'EOF'
The following is terminal output (often from a failed or noisy command).

First, plan only: do NOT run terminal commands, edit files, or apply any fix yet.

In your planning reply:
- Briefly characterize the output: what command or situation it looks like (if inferable), and success vs errors vs warnings or noise.
- One sentence: what went wrong (or what is worth attention).
- Short diagnosis (likely root cause).
- A numbered plan: concrete steps in order (which files, what commands, what to verify).
- Proposed commands and code changes as fenced blocks or bullet lists, clearly labeled as proposed — still no execution or patches.
- End with one clear question: whether to apply this plan (e.g. proceed? yes/no).
- Stop and wait for the user reply. Do not apply anything in the same turn as the plan.

Only after the user explicitly agrees (yes, y, proceed, apply, etc.): carry out the plan, verify if reasonable, then one-line summary.
EOF
)

prompt=$autobot_default_prompt

_autobot_pi() {
  pi --offline "<terminal_capture>
$output
</terminal_capture>

Context: when <earlier_terminal_context> appears above, it is recent background only; <terminal_output> is the command and output immediately before autobot — prioritize that for explanations and fixes.

<instructions>
$prompt
</instructions>"
}

_autobot_pi
