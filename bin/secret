#!/usr/bin/env bash

set -euo pipefail

_usage() {
  echo "Usage: secret <get|set|del> <name> [value]"
  echo ""
  echo "Examples:"
  echo "  secret get MY_API_KEY"
  echo "  secret set MY_API_KEY"
  echo "  secret set MY_API_KEY s3cr3t"
  echo "  secret del MY_API_KEY"
  echo "  secret del -f MY_API_KEY"
  exit 1
}

# macOS keychain helpers
_keychain_get() {
  security find-generic-password -a "$USER" -D "environment variable" \
    -s "$1" -w
}

_keychain_set() {
  local name="$1" secret="$2"
  security add-generic-password -a "$USER" -D "environment variable" \
    -s "$name" -w "$secret" -U
}

_keychain_del() {
  security delete-generic-password -a "$USER" -D "environment variable" \
    -s "$1"
}

# pass helpers
_pass_ensure_encrypt_capable() {
  local gpg_bin="$1" gpg_file line rid _unlock
  gpg_file="${PASSWORD_STORE_DIR:-$HOME/.password-store}/.gpg-id"
  [ ! -f "$gpg_file" ] && return 0
  while IFS= read -r line || [ -n "$line" ]; do
    line=$(printf '%s' "$line" | tr -d '\r')
    [ -z "$line" ] && continue
    for rid in $line; do
      [ -z "$rid" ] && continue
      printf 'x\n' | "$gpg_bin" -o /dev/null -e -r "$rid" \
        2>/dev/null && continue
      printf 'Passphrase (unlock key for encrypt subkey): ' >&2
      read -rs _unlock </dev/tty 2>/dev/null || read -rs _unlock
      printf '\n' >&2
      printf '%s\n' "$_unlock" | "$gpg_bin" --batch --pinentry-mode loopback \
        --passphrase-fd 0 --no-tty \
        --quick-add-key "$rid" rsa4096 encrypt never || return 1
    done
  done <"$gpg_file"
}

_pass_env_ready() {
  command -v pass >/dev/null || {
    echo "Error: pass not in PATH"
    return 1
  }
  local store gpg_id gpg_bin
  gpg_bin="$(command -v gpg2 >/dev/null && printf '%s' gpg2 || printf '%s' gpg)"
  store="${PASSWORD_STORE_DIR:-$HOME/.password-store}"
  if [ ! -f "$store/.gpg-id" ]; then
    gpg_id=$("$gpg_bin" --with-colons --list-secret-keys 2>/dev/null |
      grep '^fpr:' | head -1 | cut -d: -f10)
    if [ -z "$gpg_id" ]; then
      local _pp _pp2
      printf 'Passphrase for new Password Store GPG key (empty = none): '
      read -rs _pp </dev/tty
      printf '\n'
      printf 'Confirm passphrase: '
      read -rs _pp2 </dev/tty
      printf '\n'
      if [ "$_pp" != "$_pp2" ]; then
        echo "Error: Passphrases do not match"
        return 1
      fi
      printf '%s\n' "$_pp" | "$gpg_bin" --batch --pinentry-mode loopback \
        --passphrase-fd 0 --no-tty \
        --quick-gen-key "Password Store <password-store@localhost>" \
        rsa4096 default never ||
        return 1
      gpg_id=$("$gpg_bin" --with-colons --list-secret-keys 2>/dev/null |
        grep '^fpr:' | head -1 | cut -d: -f10)
      [ -n "$gpg_id" ] || return 1
    fi
    pass init "$gpg_id" || return 1
  fi
  _pass_ensure_encrypt_capable "$gpg_bin" || return 1
}

_pass_get() {
  _pass_env_ready || return 1
  pass show "$1"
}

_pass_set() {
  local name="$1" secret="$2"
  _pass_env_ready || return 1
  (
    set -o pipefail
    printf '%s\n' "$secret" | pass insert -e -f "$name"
  ) || return 1
}

_pass_del() {
  _pass_env_ready || return 1
  local store f
  store="${PASSWORD_STORE_DIR:-$HOME/.password-store}"
  f="$store/$1.gpg"
  [ -f "$f" ] || return 0
  pass rm -f "$1" || return 1
}

# Dispatch
cmd="${1:-}"
[ -z "$cmd" ] && _usage

name="${2:-}"
[ -z "$name" ] && {
  echo "Usage: secret $cmd <name>"
  exit 1
}

case "$cmd" in
get)
  if [ "$(uname -s)" = Darwin ]; then
    _keychain_get "$name"
  else
    _pass_get "$name"
  fi
  ;;
set)
  secret="${3:-}"
  if [ -z "$secret" ]; then
    printf "Enter secret for %s: " "$name"
    read -r secret
  fi
  [ -z "$secret" ] && {
    echo "Error: Empty secret"
    exit 1
  }
  if [ "$(uname -s)" = Darwin ]; then
    _keychain_set "$name" "$secret"
  else
    _pass_set "$name" "$secret"
  fi
  ;;
del)
  force=false
  if [ "$name" = "-f" ] || [ "$name" = "--force" ]; then
    force=true
    name="${3:-}"
    [ -z "$name" ] && {
      echo "Usage: secret del [-f] <name>"
      exit 1
    }
  fi
  if [ "$force" = false ]; then
    printf 'Remove %s [y/N]? ' "$name"
    read -r choice
    case "$choice" in
    [yY]) ;;
    *)
      printf "Aborted.\n"
      exit 0
      ;;
    esac
  fi
  if [ "$(uname -s)" = Darwin ]; then
    _keychain_del "$name"
  else
    _pass_del "$name"
  fi
  ;;
*)
  _usage
  ;;
esac
