### constants ##################################################################

this_path=$(cd "$(dirname "$0")" && pwd)
backup_path="$this_path/../.backup"
config_path="$HOME/.config/configent"

### configs ####################################################################

# settings.json
if [ ! -r "$backup_path/.config/openchamber/settings.json" ]; then
  if [ -r "$HOME/.config/openchamber/settings.json" ]; then
    mkdir -p "$backup_path/.config/openchamber"
    cp -P "$HOME/.config/openchamber/settings.json" \
      "$backup_path/.config/openchamber/settings.json"
  fi
fi

mkdir -p "$HOME/.config/openchamber"
ln -sfnv "$config_path/openchamber/settings.json" \
  "$HOME/.config/openchamber/settings.json"
