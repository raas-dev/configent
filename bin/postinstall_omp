#!/bin/sh

# configent (https://github.com/raas-dev/configent)
# One command automated macOS/Linux laptop/VM/container bootstrapper.
#
# Copyright(C) 2016- Anssi Syrjäsalo (http://a.syrjasalo.com)
# Licensed under GNU Lesser General Public License v3 (LGPL-3.0).

### constants ##################################################################

this_path=$(cd "$(dirname "$0")" && pwd)
backup_path="$this_path/../.backup"
config_path="$HOME/.config/configent"

### configs ####################################################################

# files
for file in config.yml mcp.json keybindings.json; do
  if [ ! -r "$backup_path/.omp/agent/$file" ]; then
    if [ -r "$HOME/.omp/agent/$file" ]; then
      mkdir -p "$backup_path/.omp/agent"
      cp -P "$HOME/.omp/agent/$file" "$backup_path/.omp/agent/$file"
    fi
  fi
  mkdir -p "$HOME/.omp/agent"
  ln -sfnv "$config_path/omp/$file" "$HOME/.omp/agent/$file"
done

# dirs
for dir in agents commands extensions hooks modules skills themes; do
  if [ ! -r "$backup_path/.omp/agent/$dir" ]; then
    if [ -r "$HOME/.omp/agent/$dir" ]; then
      mkdir -p "$backup_path/.omp/agent/$dir"
      cp -RP "$HOME/.omp/agent/$dir" "$backup_path/.omp/agent/$dir"
    fi
  fi
  mkdir -p "$HOME/.omp/agent/$dir"
  rm -rf "$HOME/.omp/agent/$dir"
  ln -sfnv "$config_path/omp/$dir" "$HOME/.omp/agent/$dir"
done

### ~/.agents dir ##############################################################

if [ ! -r "$backup_path/.agents" ]; then
  if [ -r "$HOME/.agents" ]; then
    mkdir -p "$backup_path/.agents"
    cp -RP "$HOME/.agents" "$backup_path/.agents"
  fi
fi
mkdir -p "$HOME/.agents"
rm -rf "$HOME/.agents"
ln -sfnv "$config_path/agents" "$HOME/.agents"
