### constants ##################################################################

this_path=$(cd "$(dirname "$0")" && pwd)
backup_path="$this_path/../.backup"
config_path="$HOME/.config/configent"

### configs ####################################################################

# mcoporter.jsonc
if [ ! -r "$backup_path/.mcporter/mcporter.jsonc" ]; then
  if [ -r "$HOME/.mcporter/mcporter.jsonc" ]; then
    mkdir -p "$backup_path/.mcporter"
    cp -P "$HOME/.mcporter/mcporter.jsonc" \
      "$backup_path/.mcporter/mcporter.jsonc"
  fi
fi
mkdir -p "$HOME/.mcporter"
ln -sfnv "$config_path/mcporter/mcporter.jsonc" "$HOME/.mcporter/mcporter.jsonc"
