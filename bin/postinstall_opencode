#!/bin/sh

# configent (https://github.com/raas-dev/configent)
# One command automated macOS/Linux laptop/VM/container bootstrapper.
#
# Copyright(C) 2016- Anssi Syrjäsalo (http://a.syrjasalo.com)
# Licensed under GNU Lesser General Public License v3 (LGPL-3.0).

### constants ##################################################################

this_path=$(cd "$(dirname "$0")" && pwd)
backup_path="$this_path/../.backup"
config_path="$HOME/.config/configent"

### configs ####################################################################

# files
for file in opencode.jsonc opencode.json tui.json caveman.json dcp.jsonc; do
  if [ ! -r "$backup_path/.config/opencode/$file" ]; then
    if [ -r "$HOME/.config/opencode/$file" ]; then
      mkdir -p "$backup_path/.config/opencode"
      cp -P "$HOME/.config/opencode/$file" "$backup_path/.config/opencode/$file"
    fi
  fi
  mkdir -p "$HOME/.config/opencode"
  ln -sfnv "$config_path/opencode/$file" "$HOME/.config/opencode/$file"
done

# dirs
for dir in agents commands skills plugins profiles; do
  if [ ! -r "$backup_path/.config/opencode/$dir" ]; then
    if [ -r "$HOME/.config/opencode/$dir" ]; then
      mkdir -p "$backup_path/.config/opencode/$dir"
      cp -RP "$HOME/.config/opencode/$dir" "$backup_path/.config/opencode/$dir"
    fi
  fi
  mkdir -p "$HOME/.config/opencode/$dir"
  rm -rf "$HOME/.config/opencode/$dir"
  ln -sfnv "$config_path/opencode/$dir" "$HOME/.config/opencode/$dir"
done

# AGENTS.md
if [ ! -r "$backup_path/.config/opencode/AGENTS.md" ]; then
  if [ -r "$HOME/.config/opencode/AGENTS.md" ]; then
    mkdir -p "$backup_path/.config/opencode"
    cp -P "$HOME/.config/opencode/AGENTS.md" \
      "$backup_path/.config/opencode/AGENTS.md"
  fi
fi
mkdir -p "$HOME/.config/opencode"
rm -rf "$HOME/.config/opencode/AGENTS.md"
ln -sfnv "$config_path/opencode/AGENTS.md" "$HOME/.config/opencode/AGENTS.md"

### ~/.agents dir ##############################################################

if [ ! -r "$backup_path/.agents" ]; then
  if [ -r "$HOME/.agents" ]; then
    mkdir -p "$backup_path/.agents"
    cp -RP "$HOME/.agents" "$backup_path/.agents"
  fi
fi
mkdir -p "$HOME/.agents"
rm -rf "$HOME/.agents"
ln -sfnv "$config_path/agents" "$HOME/.agents"
