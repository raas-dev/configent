#!/usr/bin/env bash
# Prefer GitHub CLI for github.com / gist HTTPS; else same pass helper as global
# gitconfig. gh must be on PATH (e.g. mise shims after tmux update-environment PATH).

here=$(
  unset CDPATH
  cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd
)

if command -v gh >/dev/null 2>&1; then
  exec gh auth git-credential "$@"
fi

if [[ -x $here/git-credential-pass ]]; then
  exec "$here/git-credential-pass" --prefix git "$@"
fi

cat >/dev/null 2>&1 || true
exit 0
