#!/bin/sh

# Prefer GitHub CLI for github.com / gist HTTPS

this_path=$(cd "$(dirname "$0")" && pwd)

if command -v gh >/dev/null 2>&1; then
  exec gh auth git-credential "$@"
fi

if [ -x "$this_path/git-credential-pass" ]; then
  exec "$this_path/git-credential-pass" --prefix git "$@"
fi

cat >/dev/null 2>&1 || true
exit 0
