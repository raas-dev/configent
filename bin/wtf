#!/bin/sh

set -e

if [ -n "$TMUX" ]; then
  exit_code=$(tmux display-message -p '#{pane_last_exit_status}')
  if [ "$exit_code" = "0" ]; then
    echo "wtf: last command exited 0 — nothing to debug"
    exit 0
  fi
  # Capture pane and extract only the output of the last command (after the last prompt line)
  pane=$(tmux capture-pane -p -S -200)
  output=$(printf '%s\n' "$pane" | awk '
    /^[^[:space:]].*[#$>][[:space:]]*$/ { buf = ""; next }
    { buf = buf $0 "\n" }
    END { printf "%s", buf }
  ')
  [ -z "$output" ] && output=$(printf '%s\n' "$pane" | tail -n 50)
elif [ -d "$HOME/.cursor/projects" ]; then
  shell_pid=$PPID
  terminal_file=$(find "$HOME/.cursor/projects/" -maxdepth 3 -name "*.txt" -path "*/terminals/*" 2>/dev/null | while read -r f; do
    if /usr/bin/grep -q "^pid: ${shell_pid}$" "$f" 2>/dev/null; then
      printf '%s %s\n' "$(stat --format '%Y' "$f")" "$f"
    fi
  done | sort -rn | head -1 | cut -d' ' -f2-)
  if [ -z "$terminal_file" ]; then
    echo "wtf: no Cursor terminal file found for shell pid ${shell_pid}"
    exit 1
  fi
  # Determine exit code: interactive shells use last_exit_code in header,
  # subshells use exit_code in trailing footer
  exit_code=$(awk '
    /^last_exit_code:/ { print $2; exit }
    /^exit_code:/      { print $2; exit }
  ' "$terminal_file")
  if [ -n "$exit_code" ] && [ "$exit_code" = "0" ]; then
    echo "wtf: last command exited 0 — nothing to debug"
    exit 0
  fi
  # Extract the output body (between the two --- blocks, strip trailing footer if present)
  body=$(awk '
    /^---$/ { n++; if (n == 2) { capture = 1; next } if (n == 3) { capture = 0 } next }
    capture { print }
  ' "$terminal_file")
  # From the body, take only the output of the last command:
  # split on prompt lines and keep the last segment
  output=$(printf '%s\n' "$body" | awk '
    /^[^[:space:]].*[#$>][[:space:]]*$/ { buf = ""; next }
    { buf = buf $0 "\n" }
    END { printf "%s", buf }
  ')
  [ -z "$output" ] && output=$(printf '%s\n' "$body" | tail -n 50)
else
  echo "Error: not in tmux or Cursor"
  exit 1
fi

prompt="${1:-Diagnose the terminal output above.

1. State what went wrong in one sentence.
2. Show the exact fix (command or code change).
3. Ask: proceed? [y/N]

If yes: apply the fix, confirm it worked, then give a one-line summary.}"

pi --no-session --offline "<terminal_output>
$output
</terminal_output>

<instructions>
$prompt
</instructions>"
