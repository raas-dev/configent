#!/bin/sh

# configent (https://github.com/raas-dev/configent)
# One command automated macOS/Linux laptop/VM/container bootstrapper.
#
# Copyright(C) 2016- Anssi Syrjäsalo (http://a.syrjasalo.com)
# Licensed under GNU Lesser General Public License v3 (LGPL-3.0).

# shim for running `kind` in lima VM

: "${NAME:="default"}"
: "${TEMPLATE:="debian"}"

if [ "$(uname -s)" = 'Darwin' ]; then
  if ! command -v limactl >/dev/null; then
    echo "Error: limactl not found on macOS, cannot start Linux VM for kind."
    exit 127
  fi

  lima_cwd=$(pwd -P)
  lima_home=$(cd "$HOME" && pwd -P)
  lima_yaml="$HOME/.config/configent/lima/$TEMPLATE.yaml"
  lima_skip_home_mount=
  [ "$lima_cwd" = "$lima_home" ] && lima_skip_home_mount=1

  # Drop mount entries whose host location no longer exists on disk.
  lima_remove_nonexistent_mounts() {
    lima_instance_yaml="$HOME/.lima/$NAME/lima.yaml"
    [ -f "$lima_instance_yaml" ] || return 0
    awk -v home="$HOME" '
      /^[a-zA-Z]/ { in_mounts = (/^mounts:/) }
      in_mounts && /^- location: / {
        loc = substr($0, 13)
        gsub(/^"|"$/, "", loc)
        sub(/^~/, home, loc)
        cmd = "test -d \"" loc "\""
        if (system(cmd) != 0) { skip=1; next }
      }
      skip && /^  / { next }
      { skip=0; print }
      ' "$lima_instance_yaml" >"${lima_instance_yaml}.tmp" &&
      mv "${lima_instance_yaml}.tmp" "$lima_instance_yaml"
  }

  lima_remove_cwd_mount() {
    lima_instance_yaml="$HOME/.lima/$NAME/lima.yaml"
    [ -f "$lima_instance_yaml" ] || return 0
    awk -v path="${lima_cwd}" -v home="${lima_home}" '
      /^- location: / {
        loc = substr($0, 13)
        gsub(/^"|"$/, "", loc)
        if (loc == path || loc == home || loc == "~") { skip=1; next }
      }
      skip && /^  / { next }
      { skip=0; print }
      ' "$lima_instance_yaml" >"${lima_instance_yaml}.tmp" &&
      mv "${lima_instance_yaml}.tmp" "$lima_instance_yaml"
  }

  # True if the path is visible inside the guest (i.e. the mount exists).
  lima_guest_cwd_exists() {
    limactl shell --workdir / --tty=false "$NAME" -- \
      test -d "$lima_cwd" >/dev/null 2>&1
  }

  lima_guest_cwd_writable() {
    limactl shell --workdir / --tty=false "$NAME" -- sh -ceu \
      "t=\"\$1/.kind-write-probe.\$\$\"; rm -f \"\$t\"; \
      touch \"\$t\"; rm -f \"\$t\"" \
      _ "$lima_cwd" >/dev/null 2>&1
  }

  lima_guest_remount_cwd_rw() {
    limactl shell --tty=false "$NAME" -- \
      sudo mount -o remount,rw "$lima_cwd" \
      >/dev/null 2>&1 || true
  }

  lima_start_mount_only() {
    lima_remove_nonexistent_mounts
    lima_remove_cwd_mount
    if [ -n "$lima_skip_home_mount" ]; then
      limactl start --name "$NAME" --tty=false --log-level=warn
    else
      limactl start --name "$NAME" --tty=false --log-level=warn \
        --mount "${lima_cwd}:w"
    fi
  }

  lima_guest_activate_cwd_mount_rw() {
    if [ -n "$lima_skip_home_mount" ]; then
      return 0
    fi
    lima_guest_remount_cwd_rw
    if lima_guest_cwd_writable; then
      return 0
    fi
    _lima_cwd_existed=
    if lima_guest_cwd_exists; then
      _lima_cwd_existed=1
      printf "Mount at %s is read-only. Restart Lima VM '%s' to fix? [y/N] " \
        "$lima_cwd" "$NAME"
    else
      printf "Mount at %s is not mounted. Restart Lima VM '%s' to fix? [y/N] " \
        "$lima_cwd" "$NAME"
    fi
    read -r _restart_answer
    case "$_restart_answer" in
    [yY]) ;;
    *)
      echo "Skipping restart."
      [ -z "$_lima_cwd_existed" ] && lima_remove_cwd_mount
      return 1
      ;;
    esac
    limactl stop "$NAME"
    lima_start_mount_only
    lima_guest_remount_cwd_rw
    if lima_guest_cwd_writable; then
      return 0
    fi
    echo "Error: Lima mount is still not writable at ${lima_cwd}" \
      "inside the VM (see: findmnt ${lima_cwd})." >&2
    exit 1
  }

  lima_create_instance() {
    net="$1"
    if [ -n "$lima_skip_home_mount" ]; then
      limactl start --name "$NAME" --tty=false "$lima_yaml" \
        --vm-type=vz \
        --network="$net" \
        --rosetta \
        --set=".env.MISE_GITHUB_TOKEN = \"$MISE_GITHUB_TOKEN\"" \
        --set=".env.EMAIL = \"$EMAIL\"" \
        --set=".env.GIT_AUTHOR_NAME = \"$GIT_AUTHOR_NAME\"" \
        --set=".env.GIT_COMMITTER_NAME = \"$GIT_COMMITTER_NAME\"" ||
        lima_start_mount_only
    else
      limactl start --name "$NAME" --tty=false "$lima_yaml" \
        --vm-type=vz \
        --network="$net" \
        --rosetta \
        --mount "${lima_cwd}:w" \
        --set=".env.MISE_GITHUB_TOKEN = \"$MISE_GITHUB_TOKEN\"" \
        --set=".env.EMAIL = \"$EMAIL\"" \
        --set=".env.GIT_AUTHOR_NAME = \"$GIT_AUTHOR_NAME\"" \
        --set=".env.GIT_COMMITTER_NAME = \"$GIT_COMMITTER_NAME\"" ||
        lima_start_mount_only
    fi
  }

  # VM already running: skip SSH probe; only SSH if mount missing or ro.
  if limactl list -q 2>/dev/null | grep -qx "$NAME"; then
    if [ -z "$lima_skip_home_mount" ]; then
      if ! lima_guest_cwd_writable; then
        lima_guest_activate_cwd_mount_rw || exit 1
      fi
    fi
  elif [ -x "/opt/socket_vmnet/bin/socket_vmnet" ]; then
    lima_create_instance lima:bridged
    lima_guest_activate_cwd_mount_rw || exit 1
  else
    lima_create_instance vzNAT
    lima_guest_activate_cwd_mount_rw || exit 1
  fi

  limactl shell --workdir "$lima_cwd" "$NAME" kind "$@"
  ret=$?

  # copy kubectl config from lima vm to host (if it exists)
  if limactl shell "$NAME" sh -c 'test -f ~/.kube/config'; then
    limactl copy "$NAME":~/.kube/config "$HOME/.lima/$NAME/kubeconfig.yaml"
  fi

  exit $ret
else
  if [ -x "$HOME/.local/bin/mise" ]; then
    "$HOME/.local/bin/mise" exec kind -- kind "$@"
  else
    echo "Error: mise not found in this Linux system."
    exit 127
  fi
fi
