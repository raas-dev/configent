#!/bin/sh

# configent (https://github.com/raas-dev/configent)
# One command automated macOS/Linux laptop/VM/container bootstrapper.
#
# Copyright(C) 2016- Anssi Syrjäsalo (http://a.syrjasalo.com)
# Licensed under GNU Lesser General Public License v3 (LGPL-3.0).

### constants ##################################################################

this_path=$(cd "$(dirname "$0")" && pwd)
backup_path="$this_path/../.backup"
config_path="$HOME/.config/configent"

### configs ####################################################################

# files
for file in settings.json CLAUDE.md RTK.md; do
  if [ ! -r "$backup_path/.claude/$file" ]; then
    if [ -r "$HOME/.claude/$file" ]; then
      mkdir -p "$backup_path/.claude"
      cp -P "$HOME/.claude/$file" "$backup_path/.claude/$file"
    fi
  fi
  mkdir -p "$HOME/.claude"
  ln -sfnv "$config_path/claude-code/$file" "$HOME/.claude/$file"
done

# dirs
for dir in commands agents skills hooks; do
  if [ ! -r "$backup_path/.claude/$dir" ]; then
    if [ -r "$HOME/.claude/$dir" ]; then
      mkdir -p "$backup_path/.claude/$dir"
      cp -RP "$HOME/.claude/$dir" "$backup_path/.claude/$dir"
    fi
  fi
  mkdir -p "$HOME/.claude/$dir"
  rm -rf "$HOME/.claude/$dir"
  ln -sfnv "$config_path/claude-code/$dir" "$HOME/.claude/$dir"
done

### ccstatusline ###############################################################

# ccstatusline binary
if command -v mise >/dev/null 2>&1; then
  mise exec node -- npm install -g ccstatusline
fi

# ccstatusline/settings.json
if [ ! -r "$backup_path/.config/ccstatusline/settings.json" ]; then
  if [ -r "$HOME/.config/ccstatusline/settings.json" ]; then
    mkdir -p "$backup_path/.config/ccstatusline"
    cp -P "$HOME/.config/ccstatusline/settings.json" \
      "$backup_path/.config/ccstatusline/settings.json"
  fi
fi
mkdir -p "$HOME/.config/ccstatusline"
ln -sfnv "$config_path/claude-code/ccstatusline/settings.json" \
  "$HOME/.config/ccstatusline/settings.json"

### ~/.agents dir ##############################################################

if [ ! -r "$backup_path/.agents" ]; then
  if [ -r "$HOME/.agents" ]; then
    mkdir -p "$backup_path/.agents"
    cp -RP "$HOME/.agents" "$backup_path/.agents"
  fi
fi
mkdir -p "$HOME/.agents"
rm -rf "$HOME/.agents"
ln -sfnv "$config_path/agents" "$HOME/.agents"

### MCP servers ################################################################

if command -v claude >/dev/null; then
  # dynamic-mcp
  if ! claude mcp get dynamic-mcp >/dev/null 2>&1; then
    claude mcp add --scope user dynamic-mcp -- dmcp
  fi
  # caveman
  claude plugin marketplace add JuliusBrussee/caveman
  claude plugin install caveman@caveman
fi
