#!/bin/sh

# configent (https://github.com/raas-dev/configent)
# One command automated macOS/Linux laptop/VM/container bootstrapper.
#
# Copyright(C) 2016- Anssi Syrjäsalo (http://a.syrjasalo.com)
# Licensed under GNU Lesser General Public License v3 (LGPL-3.0).

# Proposes git commit message generated with LLM and asks to commit

normal=$(tput sgr0)
bold=$(tput bold)
red=$(tput setaf 1)
yellow=$(tput setaf 3)
cyan=$(tput setaf 6)

OC_PROFILE="${OC_PROFILE:-git-use}"

# Shown to model + enforced in finalize_commit_message (line 1).
AI_COMMIT_SUBJECT_MAX="${AI_COMMIT_SUBJECT_MAX:-72}"
# Raw staged patch larger than this is replaced by --stat + --name-only + patch excerpt (bytes).
AI_COMMIT_DIFF_MAX_BYTES="${AI_COMMIT_DIFF_MAX_BYTES:-72000}"
# If 1 (default), synthesize a conventional message from git when the model returns nothing.
AI_COMMIT_HEURISTIC_FALLBACK="${AI_COMMIT_HEURISTIC_FALLBACK:-1}"

if ! command -v opencode >/dev/null; then
  printf "%sError: opencode not found in the system.\n" "$red"
  exit 127
fi

git_dir="$(git rev-parse --git-dir)"
backup_file="$git_dir/AI_COMMIT_BACKUP"
diff_file=$(mktemp) || exit 1
trap 'rm -f "$diff_file"' EXIT INT TERM

git diff --staged --no-color >"$diff_file" || {
  printf "%sError: Failed to get git diff.\n" "$red"
  exit 1
}
if ! [ -s "$diff_file" ]; then
  printf "%sNothing staged to commit.\n" "$red"
  exit 1
fi

diff_bytes=$(wc -c <"$diff_file" | awk '{print $1}')
diff_truncated=0
if [ "${AI_COMMIT_DIFF_MAX_BYTES:-0}" -gt 0 ] 2>/dev/null && [ "$diff_bytes" -gt "$AI_COMMIT_DIFF_MAX_BYTES" ]; then
  diff_truncated=1
  printf "%sStaged diff is %s bytes; sending summary + path list + first %s bytes of patch to the model (raise AI_COMMIT_DIFF_MAX_BYTES to send more).%s\n" \
    "$yellow" "$diff_bytes" "$AI_COMMIT_DIFF_MAX_BYTES" "$normal"
fi

if [ -f "$backup_file" ]; then
  printf "%sFound saved commit message from failed run:%s\n" "$yellow" "$normal"
  printf "\n"
  cat "$backup_file"
  printf "\n"

  if [ -z "$NONINTERACTIVE" ]; then
    printf "%sReuse (y), edit (e), new (n), quit (q) [Y/e/n/q] %s> " "${bold}${cyan}" "$normal"
    trap 'printf "\n"; rm -f "$diff_file"; exit 130' INT
    read -r reuse_choice || {
      printf "\n"
      trap 'rm -f "$diff_file"' EXIT INT TERM
      exit 130
    }
    trap 'rm -f "$diff_file"' EXIT INT TERM
    [ -z "$reuse_choice" ] && reuse_choice=y
    case "$reuse_choice" in
    [yY])
      commit_message="$(cat "$backup_file")"
      choice=y
      ;;
    [eE])
      commit_message="$(cat "$backup_file")"
      choice=e
      ;;
    [qQ])
      printf "Aborted.\n"
      exit 1
      ;;
    esac
  fi
fi

context_message=""
if [ "$diff_truncated" -eq 1 ]; then
  recent_headlines="$(git log --format="%s" -5 2>/dev/null | head -8)"
else
  recent_headlines="$(git log --format="%s" -10 2>/dev/null | head -20)"
fi
commit_rules="COMMIT MESSAGE RULES (must follow):
- Line 1: Conventional Commits subject only (type(scope)?: summary). Hard max ${AI_COMMIT_SUBJECT_MAX} characters for entire line; prefer ~50. No comma-separated clause stacks.
- Line 2: blank.
- Line 3+: optional body (bullets or sentences) for details."
[ -n "$recent_headlines" ] &&
  context_message="RECENT COMMIT MESSAGE HEADLINES FOR REFERENCE:
$recent_headlines"

if [ -n "$*" ]; then
  if [ -n "$context_message" ]; then
    context_message="$context_message

ADDITIONAL CONSTRAINTS FOR TYPE AND SCOPE: $*"
  else
    context_message="ADDITIONAL CONSTRAINTS FOR TYPE AND SCOPE: $*"
  fi
fi

# stdin for opencode: optional context + staged diff (temp file avoids argv limits).
pipe_opencode_stdin() {
  if [ "$diff_truncated" -eq 1 ]; then
    printf '%s\n\n' "$commit_rules"
    if [ -n "$context_message" ]; then
      printf '%s\n\n' "$context_message"
    fi
    printf '%s\n\n' "STAGED DIFF (full diff was ${diff_bytes} bytes; input truncated to fit the model context):
- Below: git diff --staged --stat, then changed paths, then the first ${AI_COMMIT_DIFF_MAX_BYTES} bytes of the raw patch."
    git diff --staged --stat --no-color
    printf '\n%s\n' "--- changed paths ---"
    git diff --staged --name-only --no-color
    printf '\n%s\n' "--- patch excerpt ---"
    head -c "$AI_COMMIT_DIFF_MAX_BYTES" "$diff_file" || true
    printf '\n%s\n' "[... patch excerpt ends ...]"
    return
  fi
  if [ -n "$context_message" ]; then
    printf '%s\n\n%s\n\n%s' "$commit_rules" "$context_message" "$(cat "$diff_file")"
  else
    printf '%s\n\n%s' "$commit_rules" "$(cat "$diff_file")"
  fi
}

# When the model cannot produce a subject (context errors, empty stdout, etc.).
heuristic_commit_message() {
  n=$(git diff --staged --name-only 2>/dev/null | awk 'END { print NR }')
  shortstat=$(git diff --staged --shortstat 2>/dev/null | sed 's/^[[:space:]]*//')
  scope=$(git diff --staged --name-only 2>/dev/null | awk -F/ '
    NF < 1 { next }
    { k = $1; if (k == "") next; c[k]++ }
    END {
      m = 0
      best = "repo"
      for (k in c) if (c[k] > m) { m = c[k]; best = k }
      print best
    }')
  scope=$(printf '%s' "$scope" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9_.-' | cut -c1-24)
  [ -z "$scope" ] && scope=repo
  subj="chore(${scope}): update ${n} staged paths"
  # Keep line 1 within AI_COMMIT_SUBJECT_MAX (rough cut if scope/path count is huge).
  while [ "${#subj}" -gt "$AI_COMMIT_SUBJECT_MAX" ]; do
    scope=$(printf '%s' "$scope" | cut -c2-)
    subj="chore(${scope}): update ${n} staged paths"
    [ "${#scope}" -lt 2 ] && subj="chore: update ${n} staged paths" && break
  done
  printf '%s\n\n' "$subj"
  if [ -n "$shortstat" ]; then
    printf '%s\n\n' "$shortstat"
  fi
  printf '%s\n' "Note: Generated without the LLM (diff too large, model error, or empty model output)."
}

# opencode run stdout (formatted text, not --format json) may include noise; trim edges and stray ``` fence lines.
# Find first Conventional Commits subject (known types) after stripping ANSI / UI prefixes. Match is
# case-insensitive and may appear mid-line ("Summary: chore: …") so we extract the CC span only.
finalize_commit_message() {
  awk -v max="$AI_COMMIT_SUBJECT_MAX" '
    function trimmed(s,   t) {
      t = s
      sub(/^[[:space:]]+/, "", t)
      sub(/[[:space:]]+$/, "", t)
      return t
    }
    function strip_ansi(s,   r) {
      r = s
      while (match(r, /\033\[[0-9;:]*[A-Za-z]/))
        r = substr(r, 1, RSTART - 1) substr(r, RSTART + RLENGTH)
      while (match(r, /\033\][^\033]*\033\\/))
        r = substr(r, 1, RSTART - 1) substr(r, RSTART + RLENGTH)
      return r
    }
    function normalize_visual(s,   u) {
      u = strip_ansi(trimmed(s))
      if (match(u, /^```([[:alpha:]][[:alnum:]_+-]*)?[[:space:]]*$/)) u = ""
      if (u ~ /^```/) {
        sub(/^```/, "", u)
        sub(/^[[:space:]]+/, "", u)
      }
      sub(/^(>[[:space:]]+|[-*+][[:space:]]+|[[:digit:]]+\.[[:space:]]+|#[[:space:]]+)+/, "", u)
      return u
    }
    function clamp_subject(s,   orig, t, c) {
      if (max !~ /^[0-9]+$/ || max < 20) max = 72
      orig = trimmed(s)
      if (length(orig) <= max) return orig
      t = substr(orig, 1, max)
      sub(/[[:space:]]+$/, "", t)
      c = substr(orig, max + 1, 1)
      if (c != "" && c != " " && t ~ /[^[:space:]]$/) {
        sub(/[[:space:]]+[^[:space:]]+$/, "", t)
      }
      if (t == "") t = substr(orig, 1, max)
      sub(/[[:space:]]+$/, "", t)
      return t
    }
    function is_fence_only_line(s,   t) {
      t = trimmed(s)
      return (t ~ /^```([[:alpha:]][[:alnum:]_+-]*)?[[:space:]]*$/)
    }
    function cc_prefix(   t) {
      t = "(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\\([^)]*\\))?!?:"
      return t
    }
    function find_subject_in_line(s,   u, v) {
      u = normalize_visual(s)
      if (u == "") return ""
      v = tolower(u)
      # Whole-line subject: require prefix + summary (rest of line); case-insensitive on v.
      if (match(v, "^" cc_prefix() "[[:space:]]*[[:graph:]]")) return u
      # Mid-line subject: from first CC prefix through end of line (single-line buffer only).
      if (match(v, cc_prefix() "[[:space:]]*[[:graph:]][[:print:]]*"))
        return substr(u, RSTART, RLENGTH)
      return ""
    }
    BEGIN { n = 0 }
    { buf[++n] = $0 }
    END {
      if (!n) exit
      hit = 0
      for (i = 1; i <= n; i++) {
        subj = find_subject_in_line(buf[i])
        if (subj != "") {
          hit = i
          break
        }
      }
      if (!hit) exit
      outc = 0
      out[++outc] = clamp_subject(subj)
      lastnz = 0
      for (j = hit + 1; j <= n; j++) {
        if (trimmed(buf[j]) != "") {
          lastnz = j
          break
        }
      }
      if (lastnz > 0) {
        out[++outc] = ""
        for (j = lastnz; j <= n; j++) {
          if (!(j == n && trimmed(buf[j]) == "")) out[++outc] = buf[j]
        }
      }
      m = outc
      for (i = 1; i <= m; i++) a[i] = out[i]
      while (m >= 1 && is_fence_only_line(a[1])) {
        for (i = 1; i < m; i++) a[i] = a[i + 1]
        m--
      }
      while (m >= 1 && trimmed(a[m]) == "" && m > 2) m--
      while (m >= 1 && a[m] ~ /^```[[:space:]]*$/) m--
      if (m < 1) exit
      t = a[1]
      sub(/^[[:space:]]+/, "", t)
      if (t ~ /^```/) {
        sub(/^```/, "", t)
        sub(/^[[:space:]]+/, "", t)
        a[1] = t
      }
      a[1] = clamp_subject(a[1])
      for (i = 1; i <= m; i++) print a[i]
    }'
}

if [ -z "$commit_message" ]; then
  oc_stderr=$(mktemp) || exit 1
  trap 'rm -f "$diff_file" "$oc_stderr"' EXIT INT TERM

  oc_status=0
  raw="$(pipe_opencode_stdin | oc exec "$OC_PROFILE" -- opencode run \
    --agent coder \
    --command caveman-commit \
    2>"$oc_stderr")" || oc_status=$?

  if [ "$oc_status" -ne 0 ]; then
    use_heuristic=0
    if [ "${AI_COMMIT_HEURISTIC_FALLBACK:-1}" != 0 ] && [ "${AI_COMMIT_HEURISTIC_FALLBACK:-1}" != no ] &&
      [ -s "$oc_stderr" ] && grep -qiE 'context window|input exceeds' "$oc_stderr"; then
      use_heuristic=1
    fi
    if [ "$use_heuristic" -eq 1 ]; then
      printf "%sopencode failed (exit %s) — likely input size; using heuristic commit message.%s\n" \
        "$yellow" "$oc_status" "$normal"
      commit_message="$(heuristic_commit_message)"
    else
      printf "%sError: opencode run failed (exit %s).\n" "$red" "$oc_status"
      [ -s "$oc_stderr" ] && printf "%s%s\n" "$yellow" "$(cat "$oc_stderr")"
      rm -f "$oc_stderr"
      trap 'rm -f "$diff_file"' EXIT INT TERM
      exit 1
    fi
  fi

  if [ -z "$commit_message" ]; then
    commit_message="$(printf '%s\n' "$raw" | finalize_commit_message)"
  fi
fi

if [ -z "$commit_message" ] && [ "${AI_COMMIT_HEURISTIC_FALLBACK:-1}" != 0 ] &&
  [ "${AI_COMMIT_HEURISTIC_FALLBACK:-1}" != no ]; then
  printf "%sNo usable model commit line; using heuristic message from git --shortstat.%s\n" "$yellow" "$normal"
  commit_message="$(heuristic_commit_message)"
fi

if [ -z "$commit_message" ]; then
  printf "%sError: Generated commit message is empty.%s No conventional subject line (type(scope)?: summary) after noise strip.\n" \
    "$red" "$normal"
  if [ -n "${raw:-}" ]; then
    printf "%sModel stdout (for debugging):%s\n" "$yellow" "$normal"
    printf "%s\n" "$raw"
  elif [ -n "${oc_stderr:-}" ] && [ -s "$oc_stderr" ]; then
    printf "%sopencode stderr (stdout was empty):%s\n" "$yellow" "$normal"
    head -40 "$oc_stderr" 2>/dev/null || true
    printf "%s\n" "$normal"
  fi
  [ -n "${oc_stderr:-}" ] && rm -f "$oc_stderr"
  trap 'rm -f "$diff_file"' EXIT INT TERM
  exit 1
fi

if [ -n "${oc_stderr:-}" ]; then
  rm -f "$oc_stderr"
  trap 'rm -f "$diff_file"' EXIT INT TERM
fi

if [ -z "$choice" ]; then
  printf "%s%s%s\n" "$normal" "$commit_message" "$normal"
fi

if [ -z "$NONINTERACTIVE" ] && [ -z "$choice" ]; then
  printf "\n%sCommit (y), edit (e), quit (q) [Y/e/q] %s> " "${bold}${cyan}" "$normal"
  trap 'printf "\n"; exit 130' INT
  read -r choice || {
    printf "\n"
    exit 130
  }
  trap - INT
  [ -z "$choice" ] && choice=y
elif [ -n "$NONINTERACTIVE" ]; then
  choice=y
fi

case "$choice" in
[yY])
  if git commit --message "$commit_message"; then
    rm -f "$backup_file"
  else
    printf "%sError: git commit failed (hooks?). Saving message to %s\n" "$red" "$backup_file"
    echo "$commit_message" >"$backup_file"
    exit 1
  fi
  ;;
[eE])
  if git commit --edit --message "$commit_message"; then
    rm -f "$backup_file"
  else
    printf "%sError: git commit failed.\n" "$red"
    if [ -f "$git_dir/COMMIT_EDITMSG" ]; then
      cp "$git_dir/COMMIT_EDITMSG" "$backup_file"
    else
      echo "$commit_message" >"$backup_file"
    fi
    printf "%sSaved message to %s for reuse.\n" "$yellow" "$backup_file"
    exit 1
  fi
  ;;
*)
  printf "Aborted.\n"
  exit 1
  ;;
esac
