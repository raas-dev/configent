### constants ##################################################################

this_path=$(cd "$(dirname "$0")" && pwd)
backup_path="$this_path/../.backup"
config_path="$HOME/.config/configent"

### configs ####################################################################

# config.toml
if [ ! -r "$backup_path/.agent-of-empires/config.toml" ]; then
  if [ -r "$HOME/.agent-of-empires/config.toml" ]; then
    mkdir -p "$backup_path/.agent-of-empires"
    cp -P "$HOME/.agent-of-empires/config.toml" \
      "$backup_path/.agent-of-empires/config.toml"
  fi
fi
mkdir -p "$HOME/.agent-of-empires"
ln -sfnv "$config_path/agent-of-empires/config.toml" "$HOME/.agent-of-empires/config.toml"
