#!/bin/sh

# configent (https://github.com/raas-dev/configent)
# One command automated macOS/Linux laptop/VM/container bootstrapper.
#
# Copyright(C) 2016- Anssi Syrjäsalo (http://a.syrjasalo.com)
# Licensed under GNU Lesser General Public License v3 (LGPL-3.0).

# shim for running `podman` in lima VM

: "${NAME:="default"}"
: "${TEMPLATE:="debian"}"

# Query GitHub API for latest release tag
get_latest_github_release() {
  repo="$1"
  api_url="https://api.github.com/repos/$repo/releases/latest"
  if [ -n "$MISE_GITHUB_TOKEN" ]; then
    curl -fsSL \
      -H "Authorization: token $MISE_GITHUB_TOKEN" \
      "$api_url" 2>/dev/null |
      grep -o '"tag_name": "[^"]*"' |
      head -1 |
      cut -d '"' -f 4
  else
    curl -fsSL "$api_url" 2>/dev/null |
      grep -o '"tag_name": "[^"]*"' |
      head -1 |
      cut -d '"' -f 4
  fi
}

install_docker_compose_plugin() {
  if [ ! -x "$HOME/.docker/cli-plugins/docker-compose" ]; then
    compose_version="$(get_latest_github_release docker/compose)"
    if [ -z "$compose_version" ]; then
      echo "Warning: Failed to query latest compose version," \
        "skipping installation"
      return 1
    fi
    os="$(uname | tr '[:upper:]' '[:lower:]')"
    arch="$(uname -m)"
    if [ "$os" = "darwin" ] && [ "$arch" = "arm64" ]; then
      arch="aarch64"
    fi
    echo "Downloading Docker Compose $compose_version as Docker CLI plugin" \
      "on $os ($arch)"
    mkdir -p "$HOME/.docker/cli-plugins"
    rm -f "$HOME/.docker/cli-plugins/docker-compose"
    curl -fsSL \
      "https://github.com/docker/compose/releases/download/$compose_version/" \
      "docker-compose-$os-$arch" \
      -o "$HOME/.docker/cli-plugins/docker-compose"
    chmod +x "$HOME/.docker/cli-plugins/docker-compose"
  fi
}

if [ "$(uname -s)" = 'Darwin' ]; then
  # in all cases, guest VM is required to run Podman daemon
  if ! command -v limactl >/dev/null; then
    echo "Error: limactl not found on macOS, cannot start Linux VM for podman."
    exit 127
  fi

  lima_cwd=$(pwd -P)
  lima_home=$(cd "$HOME" && pwd -P)
  lima_yaml="$HOME/.config/configent/lima/$TEMPLATE.yaml"
  lima_skip_home_mount=
  [ "$lima_cwd" = "$lima_home" ] && lima_skip_home_mount=1

  lima_remove_cwd_mount() {
    lima_instance_yaml="$HOME/.lima/$NAME/lima.yaml"
    [ -f "$lima_instance_yaml" ] || return 0
    awk -v path="${lima_cwd}" -v home="${lima_home}" '
      /^- location: / {
        loc = substr($0, 13)
        gsub(/^"|"$/, "", loc)
        if (loc == path || loc == home || loc == "~") { skip=1; next }
      }
      skip && /^  / { next }
      { skip=0; print }
      ' "$lima_instance_yaml" >"${lima_instance_yaml}.tmp" &&
      mv "${lima_instance_yaml}.tmp" "$lima_instance_yaml"
  }

  lima_guest_cwd_writable() {
    limactl shell --tty=false "$NAME" -- sh -ceu \
      "t=\"\$1/.podman-write-probe.\$\$\"; rm -f \"\$t\"; \
      touch \"\$t\"; rm -f \"\$t\"" \
      _ "$lima_cwd" 2>/dev/null
  }

  lima_guest_remount_cwd_rw() {
    limactl shell --tty=false "$NAME" -- \
      sudo mount -o remount,rw "$lima_cwd" \
      2>/dev/null || true
  }

  lima_start_mount_only() {
    lima_remove_cwd_mount
    if [ -n "$lima_skip_home_mount" ]; then
      limactl start --name "$NAME" --tty=false --log-level=warn
    else
      limactl start --name "$NAME" --tty=false --log-level=warn \
        --mount "${lima_cwd}:w"
    fi
  }

  lima_guest_activate_cwd_mount_rw() {
    if [ -n "$lima_skip_home_mount" ]; then
      return 0
    fi
    lima_guest_remount_cwd_rw
    if lima_guest_cwd_writable; then
      return 0
    fi
    limactl stop "$NAME"
    lima_start_mount_only
    lima_guest_remount_cwd_rw
    if lima_guest_cwd_writable; then
      return 0
    fi
    echo "Error: Lima mount is still not writable at ${lima_cwd}" \
      "inside the VM (see: findmnt ${lima_cwd})." >&2
    exit 1
  }

  lima_ensure_guest_cwd_writable() {
    lima_start_mount_only
    lima_guest_activate_cwd_mount_rw
  }

  lima_create_instance() {
    net="$1"
    if [ -n "$lima_skip_home_mount" ]; then
      limactl start --name "$NAME" --tty=false "$lima_yaml" \
        --vm-type=vz \
        --network="$net" \
        --rosetta \
        --set=".env.MISE_GITHUB_TOKEN = \"$MISE_GITHUB_TOKEN\"" \
        --set=".env.EMAIL = \"$EMAIL\"" \
        --set=".env.GIT_AUTHOR_NAME = \"$GIT_AUTHOR_NAME\"" \
        --set=".env.GIT_COMMITTER_NAME = \"$GIT_COMMITTER_NAME\"" ||
        lima_start_mount_only
    else
      limactl start --name "$NAME" --tty=false "$lima_yaml" \
        --vm-type=vz \
        --network="$net" \
        --rosetta \
        --mount "${lima_cwd}:w" \
        --set=".env.MISE_GITHUB_TOKEN = \"$MISE_GITHUB_TOKEN\"" \
        --set=".env.EMAIL = \"$EMAIL\"" \
        --set=".env.GIT_AUTHOR_NAME = \"$GIT_AUTHOR_NAME\"" \
        --set=".env.GIT_COMMITTER_NAME = \"$GIT_COMMITTER_NAME\"" ||
        lima_start_mount_only
    fi
  }

  if limactl list -q 2>/dev/null | grep -qx "$NAME"; then
    lima_ensure_guest_cwd_writable
  elif [ -x "/opt/socket_vmnet/bin/socket_vmnet" ]; then
    lima_create_instance lima:bridged
    lima_guest_activate_cwd_mount_rw
  else
    lima_create_instance vzNAT
    lima_guest_activate_cwd_mount_rw
  fi

  # macOS priority: mise, homebrew
  if [ -x "$HOME/.local/share/mise/shims/podman" ]; then
    podman_bin_path="$HOME/.local/share/mise/shims/podman"
  elif [ -x "/opt/homebrew/bin/podman" ]; then
    podman_bin_path="/opt/homebrew/bin/podman"
  elif [ -x "/usr/local/bin/podman" ]; then
    podman_bin_path="/usr/local/bin/podman"
  fi
  if [ -n "$podman_bin_path" ]; then
    if [ "$1" = "compose" ]; then
      install_docker_compose_plugin || return 1
      export PODMAN_COMPOSE_WARNING_LOGS=false
    fi
    "$podman_bin_path" "$@"
  else
    # no podman CLI found on macOS -> call this script on the Linux guest VM
    limactl shell --workdir "$lima_cwd" "$NAME" podman "$@"
  fi
else
  # shellcheck disable=SC2155  # will not declare separately
  if [ -x "$HOME/.local/share/mise/shims/podman" ]; then
    # user-wide podman installation (mise registry)
    if [ "$1" = "compose" ]; then
      install_docker_compose_plugin || return 1
      export PODMAN_COMPOSE_WARNING_LOGS=false
    fi
    "$HOME/.local/share/mise/shims/podman" "$@"
  elif [ -x "/usr/bin/podman" ]; then
    # system-wide podman installation (via DEB/RPM packages)
    if [ "$1" = "compose" ]; then
      install_docker_compose_plugin || return 1
      export PODMAN_COMPOSE_WARNING_LOGS=false
    fi
    "/usr/bin/podman" "$@"
  else
    echo "Error: podman not found in this Linux system."
    exit 127
  fi
fi
