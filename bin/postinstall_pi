#!/bin/sh

# configent (https://github.com/raas-dev/configent)
# One command automated macOS/Linux laptop/VM/container bootstrapper.
#
# Copyright(C) 2016- Anssi Syrjäsalo (http://a.syrjasalo.com)
# Licensed under GNU Lesser General Public License v3 (LGPL-3.0).

### constants ##################################################################

this_path=$(cd "$(dirname "$0")" && pwd)
backup_path="$this_path/../.backup"
config_path="$HOME/.config/configent"

### configs ####################################################################

# settings.json
if [ ! -r "$backup_path/.pi/agent/settings.json" ]; then
  if [ -r "$HOME/.pi/agent/settings.json" ]; then
    mkdir -p "$backup_path/.pi/agent"
    cp -P "$HOME/.pi/agent/settings.json" "$backup_path/.pi/agent/settings.json"
  fi
fi
mkdir -p "$HOME/.pi/agent"
ln -sfnv "$config_path/pi/settings.json" "$HOME/.pi/agent/settings.json"

# mcp.json
if [ ! -r "$backup_path/.pi/agent/mcp.json" ]; then
  if [ -r "$HOME/.pi/agent/mcp.json" ]; then
    mkdir -p "$backup_path/.pi/agent"
    cp -P "$HOME/.pi/agent/mcp.json" "$backup_path/.pi/agent/mcp.json"
  fi
fi
mkdir -p "$HOME/.pi/agent"
ln -sfnv "$config_path/pi/mcp.json" "$HOME/.pi/agent/mcp.json"

# keybindings.json
if [ ! -r "$backup_path/.pi/agent/keybindings.json" ]; then
  if [ -r "$HOME/.pi/agent/keybindings.json" ]; then
    mkdir -p "$backup_path/.pi/agent"
    cp -P "$HOME/.pi/agent/keybindings.json" "$backup_path/.pi/agent/keybindings.json"
  fi
fi
mkdir -p "$HOME/.pi/agent"
ln -sfnv "$config_path/pi/keybindings.json" "$HOME/.pi/agent/keybindings.json"

# extensions dir
if [ ! -r "$backup_path/.pi/agent/extensions" ]; then
  if [ -r "$HOME/.pi/agent/extensions" ]; then
    mkdir -p "$backup_path/.pi/agent/extensions"
    cp -RP "$HOME/.pi/agent/extensions" \
      "$backup_path/.pi/agent/extensions"
  fi
fi
mkdir -p "$HOME/.pi/agent/extensions"
rm -rf "$HOME/.pi/agent/extensions"
ln -sfnv "$config_path/pi/extensions" "$HOME/.pi/agent/extensions"

# prompts dir
if [ ! -r "$backup_path/.pi/agent/prompts" ]; then
  if [ -r "$HOME/.pi/agent/prompts" ]; then
    mkdir -p "$backup_path/.pi/agent/prompts"
    cp -RP "$HOME/.pi/agent/prompts" \
      "$backup_path/.pi/agent/prompts"
  fi
fi
mkdir -p "$HOME/.pi/agent/prompts"
rm -rf "$HOME/.pi/agent/prompts"
ln -sfnv "$config_path/pi/prompts" "$HOME/.pi/agent/prompts"

# skills dir
if [ ! -r "$backup_path/.pi/agent/skills" ]; then
  if [ -r "$HOME/.pi/agent/skills" ]; then
    mkdir -p "$backup_path/.pi/agent/skills"
    cp -RP "$HOME/.pi/agent/skills" \
      "$backup_path/.pi/agent/skills"
  fi
fi
mkdir -p "$HOME/.pi/agent/skills"
rm -rf "$HOME/.pi/agent/skills"
ln -sfnv "$config_path/pi/skills" "$HOME/.pi/agent/skills"

# themes dir
if [ ! -r "$backup_path/.pi/agent/themes" ]; then
  if [ -r "$HOME/.pi/agent/themes" ]; then
    mkdir -p "$backup_path/.pi/agent/themes"
    cp -RP "$HOME/.pi/agent/themes" \
      "$backup_path/.pi/agent/themes"
  fi
fi
mkdir -p "$HOME/.pi/agent/themes"
rm -rf "$HOME/.pi/agent/themes"
ln -sfnv "$config_path/pi/themes" "$HOME/.pi/agent/themes"

### ~/.agents dir ##############################################################

if [ ! -r "$backup_path/.agents" ]; then
  if [ -r "$HOME/.agents" ]; then
    mkdir -p "$backup_path/.agents"
    cp -RP "$HOME/.agents" "$backup_path/.agents"
  fi
fi
mkdir -p "$HOME/.agents"
rm -rf "$HOME/.agents"
ln -sfnv "$config_path/agents" "$HOME/.agents"

### AGENTS.md ##################################################################

if [ ! -r "$backup_path/.pi/agent/AGENTS.md" ]; then
  if [ -r "$HOME/.pi/agent/AGENTS.md" ]; then
    mkdir -p "$backup_path/.pi/agent"
    cp -RP "$HOME/.pi/agent/AGENTS.md" "$backup_path/.pi/agent/AGENTS.md"
  fi
fi
mkdir -p "$HOME/.pi/agent"
rm -rf "$HOME/.pi/agent/AGENTS.md"
ln -sfnv "$config_path/agents/AGENTS.md" "$HOME/.pi/agent/AGENTS.md"

### pi-mono-status-line ########################################################

# status-line.json
if [ ! -r "$backup_path/.pi/agent/status-line.json" ]; then
  if [ -r "$HOME/.pi/agent/status-line.json" ]; then
    mkdir -p "$backup_path/.pi/agent"
    cp -P "$HOME/.pi/agent/status-line.json" "$backup_path/.pi/agent/status-line.json"
  fi
fi
mkdir -p "$HOME/.pi/agent"
ln -sfnv "$config_path/pi/status-line.json" "$HOME/.pi/agent/status-line.json"

### pi-web-access ##############################################################

# web-search.json
if [ ! -r "$backup_path/.pi/web-search.json" ]; then
  if [ -r "$HOME/.pi/web-search.json" ]; then
    mkdir -p "$backup_path/.pi"
    cp -P "$HOME/.pi/web-search.json" "$backup_path/.pi/web-search.json"
  fi
fi
mkdir -p "$HOME/.pi"
ln -sfnv "$config_path/pi/web-search.json" "$HOME/.pi/web-search.json"

### pi-caveman #################################################################

# caveman.json
if [ ! -r "$backup_path/.pi/agent/caveman.json" ]; then
  if [ -r "$HOME/.pi/agent/caveman.json" ]; then
    mkdir -p "$backup_path/.pi/agent"
    cp -P "$HOME/.pi/agent/caveman.json" "$backup_path/.pi/agent/caveman.json"
  fi
fi
mkdir -p "$HOME/.pi"
ln -sfnv "$config_path/pi/caveman.json" "$HOME/.pi/agent/caveman.json"

### extensions #################################################################

# (pre-)install or update extensions (requires npm in PATH)
command -v mise >/dev/null && mise exec node -- pi update
