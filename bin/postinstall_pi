#!/bin/sh

# configent (https://github.com/raas-dev/configent)
# One command automated macOS/Linux laptop/VM/container bootstrapper.
#
# Copyright(C) 2016- Anssi Syrjäsalo (http://a.syrjasalo.com)
# Licensed under GNU Lesser General Public License v3 (LGPL-3.0).

### constants ##################################################################

this_path=$(cd "$(dirname "$0")" && pwd)
backup_path="$this_path/../.backup"
config_path="$HOME/.config/configent"

### configs ####################################################################

# files
for file in settings.json keybindings.json caveman.json mcp.json \
  status-line.json promptsmith-settings.json pi-vcc-config.json; do
  if [ ! -r "$backup_path/.pi/agent/$file" ]; then
    if [ -r "$HOME/.pi/agent/$file" ]; then
      mkdir -p "$backup_path/.pi/agent"
      cp -P "$HOME/.pi/agent/$file" "$backup_path/.pi/agent/$file"
    fi
  fi
  mkdir -p "$HOME/.pi/agent"
  ln -sfnv "$config_path/pi/$file" "$HOME/.pi/agent/$file"
done

# dirs
for dir in extensions prompts skills themes profiles; do
  if [ ! -r "$backup_path/.pi/agent/$dir" ]; then
    if [ -r "$HOME/.pi/agent/$dir" ]; then
      mkdir -p "$backup_path/.pi/agent/$dir"
      cp -RP "$HOME/.pi/agent/$dir" "$backup_path/.pi/agent/$dir"
    fi
  fi
  mkdir -p "$HOME/.pi/agent/$dir"
  rm -rf "$HOME/.pi/agent/$dir"
  ln -sfnv "$config_path/pi/$dir" "$HOME/.pi/agent/$dir"
done

### ~/.agents dir ##############################################################

if [ ! -r "$backup_path/.agents" ]; then
  if [ -r "$HOME/.agents" ]; then
    mkdir -p "$backup_path/.agents"
    cp -RP "$HOME/.agents" "$backup_path/.agents"
  fi
fi
mkdir -p "$HOME/.agents"
rm -rf "$HOME/.agents"
ln -sfnv "$config_path/agents" "$HOME/.agents"

### AGENTS.md ##################################################################

if [ ! -r "$backup_path/.pi/agent/AGENTS.md" ]; then
  if [ -r "$HOME/.pi/agent/AGENTS.md" ]; then
    mkdir -p "$backup_path/.pi/agent"
    cp -P "$HOME/.pi/agent/AGENTS.md" "$backup_path/.pi/agent/AGENTS.md"
  fi
fi
mkdir -p "$HOME/.pi/agent"
rm -rf "$HOME/.pi/agent/AGENTS.md"
ln -sfnv "$config_path/agents/AGENTS.md" "$HOME/.pi/agent/AGENTS.md"

### pi-lens ####################################################################

# pi-lens.json
if [ ! -r "$backup_path/.pi-lens/config.json" ]; then
  if [ -r "$HOME/.pi-lens/config.json" ]; then
    mkdir -p "$backup_path/.pi-lens"
    cp -P "$HOME/.pi-lens/config.json" "$backup_path/.pi-lens/config.json"
  fi
fi
mkdir -p "$HOME/.pi-lens"
ln -sfnv "$config_path/pi/pi-lens.json" "$HOME/.pi-lens/config.json"

### pi-web-access ##############################################################

# web-search.json
if [ ! -r "$backup_path/.pi/web-search.json" ]; then
  if [ -r "$HOME/.pi/web-search.json" ]; then
    mkdir -p "$backup_path/.pi"
    cp -P "$HOME/.pi/web-search.json" "$backup_path/.pi/web-search.json"
  fi
fi
mkdir -p "$HOME/.pi"
ln -sfnv "$config_path/pi/web-search.json" "$HOME/.pi/web-search.json"

### extensions #################################################################

# (pre-)install or update extensions (requires npm in PATH)
command -v mise >/dev/null && mise exec node -- pi update --extensions

### nono sandbox compatibility #################################################

# Install node-based pi for nono (see sb) - bun binary can't find npm in sandbox
if command -v mise >/dev/null; then
  mise exec node -- npm install -g @earendil-works/pi-coding-agent
fi
