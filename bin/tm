#!/bin/sh

# Prefer tmux from mise over system tmux
mise_data="${MISE_DATA_DIR:-$HOME/.local/share/mise}"
if [ -d "$mise_data/shims" ]; then
  PATH="$mise_data/shims:$PATH"
  export PATH
fi

session_name="$(basename "$PWD")"
gui=0

show_help() {
  cat <<EOF
Usage: tm [OPTIONS] [COMMAND]

Create or attach to a tmux session named after the current directory.

Options:
  -s NAME       Set session name (default: current directory name)
  -g, --gui     Show tmux status bar
  -h, --help    Show this help message

If inside tmux, opens a new window.
If session exists, creates a grouped session.
Any additional arguments are passed as the command to run.
EOF
  exit 0
}

while [ $# -gt 0 ]; do
  case "$1" in
  -h | --help)
    show_help
    ;;
  -s)
    session_name="$2"
    shift 2
    ;;
  -g | --gui)
    gui=1
    shift
    ;;
  -s*)
    session_name="${1#-s}"
    shift
    ;;
  *)
    break
    ;;
  esac
done

if [ -n "$TMUX" ]; then
  if [ "$gui" -eq 1 ]; then
    tmux set-option status on
  fi
  exec tmux new-window "$@"
elif tmux has-session -t "$session_name" 2>/dev/null; then
  # Find unique grouped session name
  i=2
  grouped_name="${session_name}#${i}"
  while tmux has-session -t "$grouped_name" 2>/dev/null; do
    i=$((i + 1))
    grouped_name="${session_name}#${i}"
  done

  if [ "$gui" -eq 1 ]; then
    exec tmux new-session \
      -t "$session_name" -s "${grouped_name}" \; \
      set-option status on \; \
      new-window "$@"
  else
    exec tmux new-session \
      -t "$session_name" -s "$grouped_name" \; \
      set-option status off \; \
      new-window "$@"
  fi
else
  if [ "$gui" -eq 1 ]; then
    exec tmux new-session -s "$session_name" "$@"
  else
    exec tmux new-session -s "$session_name" \; \
      set-option status off
  fi
fi
