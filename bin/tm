#!/bin/sh

# Prefer tmux from mise over system tmux
mise_data="${MISE_DATA_DIR:-$HOME/.local/share/mise}"
if [ -d "$mise_data/shims" ]; then
  PATH="$mise_data/shims:$PATH"
  export PATH
fi

session_name="$(hostname)"

while getopts "s:" opt; do
  case $opt in
  s) session_name="$OPTARG" ;;
  *)
    echo "Usage: $0 [-s session_name]" >&2
    exit 1
    ;;
  esac
done

shift $((OPTIND - 1))

if tmux has-session -t "$session_name" 2>/dev/null; then
  if [ $# -gt 0 ]; then
    exec tmux new-window -t "$session_name" "$@" \; attach-session -t "$session_name"
  else
    exec tmux attach-session -t "$session_name"
  fi
else
  exec tmux new-session -s "$session_name" "$@"
fi
