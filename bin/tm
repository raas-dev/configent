#!/bin/sh

# Prefer tmux from mise over system tmux
mise_data="${MISE_DATA_DIR:-$HOME/.local/share/mise}"
if [ -d "$mise_data/shims" ]; then
  PATH="$mise_data/shims:$PATH"
  export PATH
fi

session_name="$(basename "$PWD")"
resume=0

while [ $# -gt 0 ]; do
  case "$1" in
  -s)
    session_name="$2"
    shift 2
    ;;
  -r | --resume)
    resume=1
    shift
    ;;
  -s*)
    session_name="${1#-s}"
    shift
    ;;
  *)
    break
    ;;
  esac
done

if [ -n "$TMUX" ]; then
  if [ "$resume" -eq 1 ]; then
    # Already in tmux + resume → show message, exit error
    tmux display-message "Already inside tmux"
    exit 1
  else
    # Already in tmux → open new window
    exec tmux new-window -n "$session_name" "$@"
  fi
elif tmux has-session -t "$session_name" 2>/dev/null; then
  # Find unique grouped session name
  i=2
  grouped_name="${session_name}#${i}"
  while tmux has-session -t "$grouped_name" 2>/dev/null; do
    i=$((i + 1))
    grouped_name="${session_name}#${i}"
  done

  if [ "$resume" -eq 1 ]; then
    # Grouped view: shared windows, independent nav, status bar
    exec tmux new-session \
      -t "$session_name" -s "$grouped_name" \; \
      set-option -t "$grouped_name" status on
  else
    # Grouped view + new window, no status bar
    exec tmux new-session \
      -t "$session_name" -s "$grouped_name" \; \
      set-option -t "$grouped_name" status off \; \
      new-window "$@"
  fi
else
  if [ "$resume" -eq 1 ]; then
    exec tmux new-session -s "$session_name" "$@"
  else
    exec tmux new-session -s "$session_name" \; \
      set-option status off
  fi
fi
