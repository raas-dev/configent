#!/bin/sh

# Prefer tmux from mise over system tmux
mise_data="${MISE_DATA_DIR:-$HOME/.local/share/mise}"
if [ -d "$mise_data/shims" ]; then
  PATH="$mise_data/shims:$PATH"
  export PATH
fi

session_name="$(basename "$PWD")"

new_window=0
while getopts "s:w" opt; do
  case $opt in
  s) session_name="$OPTARG" ;;
  w) new_window=1 ;;
  *)
    echo "Usage: $0 [-s session_name] [-w] [command...]" >&2
    exit 1
    ;;
  esac
done

shift $((OPTIND - 1))

if [ -n "$TMUX" ]; then
  # Already inside tmux → open new window in current session
  exec tmux new-window -n "$session_name" "$@"
elif tmux has-session -t "$session_name" 2>/dev/null; then
  if [ "$new_window" -eq 1 ] || [ $# -gt 0 ]; then
    exec tmux new-window -t "$session_name" "$@" \; attach-session -t "$session_name"
  else
    exec tmux attach-session -t "$session_name"
  fi
else
  exec tmux new-session -s "$session_name" "$@"
fi
