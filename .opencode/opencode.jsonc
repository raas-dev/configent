{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["https://raw.githubusercontent.com/JuliusBrussee/caveman/refs/heads/main/rules/caveman-activate.md"],
  "mcp": {
    "dynamic-mcp": {
      "command": [
        "dmcp"
      ],
      "type": "local"
    }
  },
  "model": "minimax-coding-plan/MiniMax-M2.7",
  "plugin": [
    "oh-my-openagent",
    "opencode-pty",
    "opencode-scheduler"
  ]
}
