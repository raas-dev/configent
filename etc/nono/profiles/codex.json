{
  "meta": {
    "name": "codex",
    "description": "OpenAI Codex CLI"
  },
  "extends": "default",
  "groups": {
    "include": [
      "git_config"
    ]
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.codex",
      "$HOME/.config/configent/codex",
      "/tmp"
    ],
    "read": [
      "$HOME/.agents",
      "$HOME/.local/share/mise",
      "$HOME/.local/configent/bin",
      "$HOME/.config/configent/mcp"
    ],
    "read_file": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile"
    ],
    "bypass_protection": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile"
    ]
  },
  "environment": {
    "allow_vars": [
      "PATH",
      "HOME",
      "USER",
      "SHELL",
      "TMPDIR",
      "LANG",
      "TERM",
      "COLORTERM",
      "TERM_PROGRAM",
      "TERM_PROGRAM_VERSION",
      "NO_COLOR",
      "FORCE_COLOR",
      "EMAIL",
      "GIT_AUTHOR_NAME",
      "GIT_COMMITTER_NAME",
      "DYNAMIC_MCP_CONFIG",
      "NONO_PROXY_TOKEN",
      "GITHUB_TOKEN",
      "CONTEXT7_API_KEY",
      "EXA_API_KEY",
      "OPENAI_API_KEY"
    ]
  }
}
