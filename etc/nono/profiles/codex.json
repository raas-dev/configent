{
  "meta": {
    "name": "codex",
    "description": "OpenAI Codex CLI"
  },
  "extends": "default",
  "groups": {
    "include": [
      "git_config"
    ]
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.codex",
      "$HOME/.config/configent/codex",
      "/tmp"
    ],
    "read": [
      "$HOME/.agents",
      "$HOME/.local/share/mise",
      "$HOME/.local/configent/bin",
      "$HOME/.config/configent/mcp"
    ],
    "read_file": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile"
    ],
    "bypass_protection": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile"
    ]
  },
  "environment": {
    "allow_vars": [
      "PATH",
      "HOME",
      "USER",
      "SHELL",
      "TMPDIR",
      "LANG",
      "TERM",
      "COLORTERM",
      "TERM_PROGRAM",
      "TERM_PROGRAM_VERSION",
      "NO_COLOR",
      "FORCE_COLOR",
      "EMAIL",
      "GIT_AUTHOR_NAME",
      "GIT_COMMITTER_NAME",
      "DYNAMIC_MCP_CONFIG",
      "NONO_PROXY_TOKEN"
    ]
  },
  "network": {
    "credentials": [
      "github",
      "context7",
      "exa",
      "codex"
    ],
    "custom_credentials": {
      "github": {
        "upstream": "https://api.github.com",
        "credential_key": "github_token",
        "env_var": "GITHUB_TOKEN",
        "inject_header": "Authorization",
        "credential_format": "token {}"
      },
      "context7": {
        "upstream": "https://api.context7.com",
        "credential_key": "context7_api_key",
        "env_var": "CONTEXT7_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "exa": {
        "upstream": "https://api.exa.ai",
        "credential_key": "exa_api_key",
        "env_var": "EXA_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "codex": {
        "upstream": "https://api.openai.com",
        "credential_key": "openai_api_key",
        "env_var": "OPENAI_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      }
    }
  }
}
