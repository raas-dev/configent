{
  "meta": {
    "name": "codex",
    "version": "1.0.0",
    "description": "OpenAI Codex CLI"
  },
  "groups": {
    "include": [
      "git_config"
    ]
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.codex",
      "$HOME/.local/share/mise"
    ],
    "read": [
      "$HOME/configent/dotfiles"
    ],
    "bypass_protection": [
      "$HOME/configent/dotfiles/.zshrc",
      "$HOME/configent/dotfiles/.bashrc",
      "$HOME/configent/dotfiles/.bash_profile",
      "$HOME/configent/dotfiles/.profile"
    ]
  },
  "network": {
    "block": false
  }
}
