{
  "meta": {
    "name": "codex-macos",
    "description": "OpenAI Codex CLI (macOS)"
  },
  "extends": "codex",
  "filesystem": {
    "read_file": [
      "$HOME/.CFUserTextEncoding"
    ],
    "suppress_save_prompt": [
      "/Users"
    ]
  },
  "environment": {
    "allow_vars": [
      "NONO_PROXY_TOKEN"
    ]
  },
  "network": {
    "credentials": [
      "github",
      "context7",
      "openai"
    ],
    "custom_credentials": {
      "github": {
        "upstream": "https://api.github.com",
        "credential_key": "github_token",
        "env_var": "GITHUB_TOKEN",
        "inject_header": "Authorization",
        "credential_format": "token {}"
      },
      "context7": {
        "upstream": "https://api.context7.com",
        "credential_key": "context7_api_key",
        "env_var": "CONTEXT7_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "openai": {
        "upstream": "https://api.openai.com",
        "credential_key": "openai_api_key",
        "env_var": "OPENAI_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      }
    }
  }
}
