{
  "meta": {
    "name": "pi-macos",
    "description": "Pi Coding Agent (macOS)"
  },
  "extends": "pi",
  "filesystem": {
    "read_file": [
      "$HOME/.CFUserTextEncoding"
    ],
    "suppress_save_prompt": [
      "/Users"
    ]
  },
  "environment": {
    "allow_vars": [
      "NONO_PROXY_TOKEN"
    ]
  },
  "network": {
    "credentials": [
      "github",
      "context7",
      "zai",
      "minimax"
    ],
    "custom_credentials": {
      "github": {
        "upstream": "https://api.github.com",
        "credential_key": "github_token",
        "env_var": "GITHUB_TOKEN",
        "inject_header": "Authorization",
        "credential_format": "token {}"
      },
      "context7": {
        "upstream": "https://api.context7.com",
        "credential_key": "context7_api_key",
        "env_var": "CONTEXT7_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "zai": {
        "upstream": "https://api.z.ai/api/coding/paas/v4",
        "credential_key": "zai_api_key",
        "env_var": "ZAI_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "minimax": {
        "upstream": "https://api.minimax.io/v1",
        "credential_key": "minimax_api_key",
        "env_var": "MINIMAX_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      }
    }
  },
  "unsafe_macos_seatbelt_rules": [
    "(allow user-preference-read)",
    "(allow system-socket (socket-domain 32) (socket-type 2) (socket-protocol 2))"
  ]
}
