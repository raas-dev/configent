{
  "meta": {
    "name": "opencode",
    "version": "1.0.0",
    "description": "OpenCode"
  },
  "extends": "default",
  "groups": {
    "include": [
      "git_config"
    ]
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.claude",
      "$HOME/.config/opencode",
      "$HOME/.cache/opencode",
      "$HOME/.local/share/opencode",
      "$HOME/.local/state/opencode"
    ],
    "read": [
      "$HOME/.agents",
      "$HOME/.local/share/mise"
    ]
  },
  "environment": {
    "allow_vars": [
      "PATH",
      "HOME",
      "USER",
      "SHELL",
      "TMPDIR",
      "LANG",
      "TERM",
      "COLORTERM",
      "TERM_PROGRAM",
      "TERM_PROGRAM_VERSION",
      "NO_COLOR",
      "FORCE_COLOR",
      "EMAIL",
      "GIT_AUTHOR_NAME",
      "GIT_COMMITTER_NAME",
      "DYNAMIC_MCP_CONFIG",
      "NONO_PROXY_TOKEN"
    ]
  },
  "network": {
    "block": false,
    "credentials": [
      "github",
      "context7",
      "exa",
      "opencode"
    ],
    "custom_credentials": {
      "github": {
        "upstream": "https://api.github.com",
        "credential_key": "github_token",
        "env_var": "GITHUB_TOKEN",
        "inject_header": "Authorization",
        "credential_format": "token {}"
      },
      "context7": {
        "upstream": "https://api.context7.com",
        "credential_key": "context7_api_key",
        "env_var": "CONTEXT7_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "exa": {
        "upstream": "https://api.exa.ai",
        "credential_key": "exa_api_key",
        "env_var": "EXA_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "opencode": {
        "upstream": "https://api.opencode.ai",
        "credential_key": "opencode_api_key",
        "env_var": "OPENCODE_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      }
    }
  },
  "unsafe_macos_seatbelt_rules": [
    "(allow file-read-metadata file-read-data (subpath \"/Users\"))",
    "(deny file-read-metadata file-read-data (regex #\"^/Users/[^/]+/\\.rclocal$\"))",
    "(deny file-read-metadata file-read-data (regex #\"^/Users/[^/]+/\\.netrc$\"))",
    "(deny file-read-metadata file-read-data (regex #\"^/Users/[^/]+/\\.npmrc$\"))",
    "(deny file-read-metadata file-read-data (regex #\"^/Users/[^/]+/\\.pypirc$\"))",
    "(deny file-read-metadata file-read-data (regex #\"^/Users/[^/]+/\\.vsce$\"))",
    "(deny file-read-metadata file-read-data (regex #\"^/Users/[^/]+/\\.git-credentials$\"))",
    "(deny file-read-metadata file-read-data (regex #\"^/Users/[^/]+/\\.ssh\"))",
    "(deny file-read-metadata file-read-data (regex #\"^/Users/[^/]+/\\.gnupg\"))",
    "(deny file-read-metadata file-read-data (regex #\"^/Users/[^/]+/\\.env$\"))",
    "(deny file-read-metadata file-read-data (regex #\"^/Users/[^/]+/\\.bash_history$\"))",
    "(deny file-read-metadata file-read-data (regex #\"^/Users/[^/]+/\\.zsh_history$\"))"
  ]
}
