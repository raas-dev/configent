{
  "meta": {
    "name": "opencode",
    "version": "1.0.0",
    "description": "OpenCode"
  },
  "groups": {
    "include": [
      "git_config"
    ]
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.claude",
      "$HOME/.config/opencode",
      "$HOME/.cache/opencode",
      "$HOME/.local/share/opencode",
      "$HOME/.local/state/opencode",
      "$HOME/.local/share/mise"
    ],
    "read": [
      "$HOME/.config/configent",
      "$HOME/.local/configent/bin"
    ],
    "bypass_protection": [
      "$HOME/.config/configent",
      "$HOME/.local/configent/bin",
      "$HOME/configent/dotfiles/.zshrc",
      "$HOME/configent/dotfiles/.bashrc",
      "$HOME/configent/dotfiles/.bash_profile",
      "$HOME/configent/dotfiles/.profile"
    ]
  },
  "network": {
    "block": false
  }
}
