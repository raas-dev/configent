{
  "meta": {
    "name": "opencode",
    "description": "OpenCode"
  },
  "extends": "default",
  "allow_parent_of_protected": true,
  "groups": {
    "include": [
      "git_config"
    ]
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.cache",
      "$HOME/.claude",
      "$HOME/.config/opencode",
      "$HOME/.local/share/opencode",
      "$HOME/.local/share/opentui",
      "$HOME/.local/share/opencode-goal-plugin",
      "$HOME/.local/share/uv/tools",
      "$HOME/.local/state",
      "$HOME/.config/configent/opencode",
      "/tmp",
      "$HOME/.npm",
      "$HOME/.zai"
    ],
    "read": [
      "$HOME/.agents",
      "$HOME/.local/share/mise",
      "$HOME/.local/share/uv",
      "$HOME/.config/uv",
      "$HOME/.local/configent/bin",
      "$HOME/.config/configent/claude-code",
      "$HOME/.config/configent/mcp"
    ],
    "allow_file": [
      "$HOME/.claude.json"
    ],
    "read_file": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile"
    ],
    "suppress_save_prompt": [
      "$HOME"
    ],
    "bypass_protection": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile"
    ]
  },
  "environment": {
    "allow_vars": [
      "PATH",
      "HOME",
      "USER",
      "SHELL",
      "TMPDIR",
      "LANG",
      "TERM",
      "COLORTERM",
      "TERM_PROGRAM",
      "TERM_PROGRAM_VERSION",
      "NO_COLOR",
      "FORCE_COLOR",
      "EMAIL",
      "GIT_AUTHOR_NAME",
      "GIT_COMMITTER_NAME",
      "DYNAMIC_MCP_CONFIG",
      "NONO_PROXY_TOKEN",
      "GITHUB_TOKEN",
      "CONTEXT7_API_KEY",
      "EXA_API_KEY",
      "ZAI_API_KEY",
      "MINIMAX_API_KEY"
    ],
    "set_vars": {
      "npm_config_script_shell": "/bin/sh"
    }
  }
}
