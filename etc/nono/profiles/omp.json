{
  "meta": {
    "name": "omp",
    "description": "oh-my-pi"
  },
  "extends": "default",
  "groups": {
    "include": [
      "git_config"
    ]
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.omp",
      "$HOME/.config/configent/omp",
      "/tmp"
    ],
    "read": [
      "$HOME/.agents",
      "$HOME/.claude",
      "$HOME/.local/share/mise",
      "$HOME/.local/configent/bin",
      "$HOME/.config/configent/claude-code",
      "$HOME/.config/configent/mcp"
    ],
    "read_file": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile",
      "$HOME/.cargo/bin/cargo",
      "$HOME/.claude/settings.json",
      "$HOME/.config/opencode/opencode.json"
    ],
    "suppress_save_prompt": [
      "$HOME"
    ],
    "bypass_protection": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile"
    ]
  },
  "environment": {
    "allow_vars": [
      "PATH",
      "HOME",
      "USER",
      "SHELL",
      "TMPDIR",
      "LANG",
      "TERM",
      "COLORTERM",
      "TERM_PROGRAM",
      "TERM_PROGRAM_VERSION",
      "NO_COLOR",
      "FORCE_COLOR",
      "EMAIL",
      "GIT_AUTHOR_NAME",
      "GIT_COMMITTER_NAME",
      "DYNAMIC_MCP_CONFIG"
    ]
  },
  "network": {
    "open_port": [
      1234,
      8080,
      11434
    ]
  }
}
