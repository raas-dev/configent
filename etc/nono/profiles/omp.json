{
  "meta": {
    "name": "omp",
    "description": "oh-my-pi"
  },
  "extends": "default",
  "groups": {
    "include": [
      "git_config"
    ]
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.omp",
      "$HOME/.config/configent/omp",
      "/tmp"
    ],
    "read": [
      "$HOME/.agents",
      "$HOME/.local/share/mise",
      "$HOME/.local/configent/bin",
      "$HOME/.config/configent/claude-code",
      "$HOME/.config/configent/mcp",
      "$HOME/.claude"
    ],
    "read_file": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile",
      "$HOME/.CFUserTextEncoding",
      "$HOME/.cargo/bin/cargo",
      "$HOME/.claude/settings.json",
      "$HOME/.config/opencode/opencode.json"
    ],
    "bypass_protection": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile"
    ]
  },
  "environment": {
    "allow_vars": [
      "PATH",
      "HOME",
      "USER",
      "SHELL",
      "TMPDIR",
      "LANG",
      "TERM",
      "COLORTERM",
      "TERM_PROGRAM",
      "TERM_PROGRAM_VERSION",
      "NO_COLOR",
      "FORCE_COLOR",
      "EMAIL",
      "GIT_AUTHOR_NAME",
      "GIT_COMMITTER_NAME",
      "GITHUB_TOKEN",
      "CONTEXT7_API_KEY",
      "EXA_API_KEY",
      "DYNAMIC_MCP_CONFIG",
      "MINIMAX_API_KEY",
      "ZAI_API_KEY"
    ]
  }
}
