{
  "meta": {
    "name": "claude-macos",
    "description": "Claude Code CLI (macOS)"
  },
  "extends": "claude",
  "filesystem": {
    "allow": [
      "$HOME/Library/Caches/claude-cli-nodejs"
    ],
    "read": [
      "$HOME/Applications/Claude Code URL Handler.app",
      "$HOME/Library/Application Support/Chromium",
      "$HOME/Library/Application Support/Google/Chrome",
      "$HOME/Library/Application Support/BraveSoftware/Brave-Browser"
    ],
    "read_file": [
      "$HOME/.CFUserTextEncoding",
      "$HOME/Library/Keychains/login.keychain-db"
    ],
    "suppress_save_prompt": [
      "/Users"
    ],
    "bypass_protection": [
      "$HOME/Library/Application Support/Chromium",
      "$HOME/Library/Application Support/Google/Chrome",
      "$HOME/Library/Application Support/BraveSoftware/Brave-Browser",
      "$HOME/Library/Keychains/login.keychain-db"
    ]
  },
  "environment": {
    "allow_vars": [
      "NONO_PROXY_TOKEN"
    ]
  },
  "network": {
    "credentials": [
      "github",
      "context7",
      "exa"
    ],
    "custom_credentials": {
      "github": {
        "upstream": "https://api.github.com",
        "credential_key": "github_token",
        "env_var": "GITHUB_TOKEN",
        "inject_header": "Authorization",
        "credential_format": "token {}"
      },
      "context7": {
        "upstream": "https://api.context7.com",
        "credential_key": "context7_api_key",
        "env_var": "CONTEXT7_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "exa": {
        "upstream": "https://api.exa.ai",
        "credential_key": "exa_api_key",
        "env_var": "EXA_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      }
    }
  },
  "unsafe_macos_seatbelt_rules": [
    "(allow user-preference-read)"
  ]
}
