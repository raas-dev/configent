{
  "meta": {
    "name": "claude",
    "description": "Claude Code CLI"
  },
  "extends": "default",
  "groups": {
    "include": [
      "git_config"
    ]
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.claude",
      "$HOME/.config/configent/claude-code",
      "$HOME/Library/Caches/claude-cli-nodejs",
      "/tmp"
    ],
    "read": [
      "$HOME/.agents",
      "$HOME/.local/share/mise",
      "$HOME/.local/configent/bin",
      "$HOME/.config/configent/mcp",
      "$HOME/.git",
      "$HOME/Library/Keychains",
      "$HOME/Applications/Claude Code URL Handler.app",
      "$HOME/Library/Application Support/Chromium",
      "$HOME/Library/Application Support/Google/Chrome",
      "$HOME/Library/Application Support/BraveSoftware/Brave-Browser"
    ],
    "allow_file": [
      "$HOME/.claude.json"
    ],
    "read_file": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile",
      "$HOME/.CFUserTextEncoding",
      "$HOME/.claude.json.lock",
      "$HOME/Library/Keychains/login.keychain-db"
    ],
    "bypass_protection": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile",
      "$HOME/Library/Application Support/Google/Chrome",
      "$HOME/Library/Keychains",
      "$HOME/Library/Keychains/login.keychain-db"
    ]
  },
  "environment": {
    "allow_vars": [
      "PATH",
      "HOME",
      "USER",
      "SHELL",
      "TMPDIR",
      "LANG",
      "TERM",
      "COLORTERM",
      "TERM_PROGRAM",
      "TERM_PROGRAM_VERSION",
      "NO_COLOR",
      "FORCE_COLOR",
      "EMAIL",
      "GIT_AUTHOR_NAME",
      "GIT_COMMITTER_NAME",
      "DYNAMIC_MCP_CONFIG",
      "CLAUDE_CODE_OAUTH_TOKEN",
      "NONO_PROXY_TOKEN"
    ]
  },
  "network": {
    "block": false,
    "credentials": [
      "github",
      "context7",
      "exa"
    ],
    "custom_credentials": {
      "github": {
        "upstream": "https://api.github.com",
        "credential_key": "github_token",
        "env_var": "GITHUB_TOKEN",
        "inject_header": "Authorization",
        "credential_format": "token {}"
      },
      "context7": {
        "upstream": "https://api.context7.com",
        "credential_key": "context7_api_key",
        "env_var": "CONTEXT7_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "exa": {
        "upstream": "https://api.exa.ai",
        "credential_key": "exa_api_key",
        "env_var": "EXA_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      }
    }
  },
  "unsafe_macos_seatbelt_rules": [
    "(allow user-preference-read)",
    "(allow file-read-metadata (literal \"/home\"))"
  ]
}
