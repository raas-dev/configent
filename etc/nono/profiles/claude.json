{
  "meta": {
    "name": "claude",
    "version": "1.0.0",
    "description": "Claude Code CLI"
  },
  "groups": {
    "include": [
      "git_config"
    ]
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.agents",
      "$HOME/.claude"
    ],
    "read": [
      "$HOME/.local/share/mise"
    ],
    "allow_file": [
      "$HOME/.claude.json"
    ]
  },
  "network": {
    "block": false
  },
  "environment": {
    "allow_vars": [
      "PATH",
      "HOME",
      "USER",
      "SHELL",
      "TMPDIR",
      "LANG",
      "TERM",
      "COLORTERM",
      "TERM_PROGRAM",
      "TERM_PROGRAM_VERSION",
      "NO_COLOR",
      "FORCE_COLOR",
      "EMAIL",
      "GIT_AUTHOR_NAME",
      "GIT_COMMITTER_NAME",
      "GITHUB_TOKEN",
      "CONTEXT7_API_KEY",
      "EXA_API_KEY",
      "DYNAMIC_MCP_CONFIG",
      "ANTHROPIC_API_KEY",
      "CLAUDE_CODE_OAUTH_TOKEN"
    ]
  }
}
