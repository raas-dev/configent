{
  "meta": {
    "name": "claude",
    "version": "1.0.0",
    "description": "Claude Code CLI"
  },
  "groups": {
    "include": [
      "git_config"
    ]
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.claude",
      "$HOME/.local/share/mise"
    ],
    "read": [
      "$HOME/configent/dotfiles"
    ],
    "read_file": [
      "$HOME/.claude.json"
    ],
    "bypass_protection": [
      "$HOME/configent/dotfiles/.zshrc",
      "$HOME/configent/dotfiles/.bashrc",
      "$HOME/configent/dotfiles/.bash_profile",
      "$HOME/configent/dotfiles/.profile"
    ]
  },
  "network": {
    "block": false
  }
}
