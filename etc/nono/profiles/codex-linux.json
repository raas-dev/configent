{
  "meta": {
    "name": "codex-linux",
    "description": "OpenAI Codex CLI (Linux)"
  },
  "extends": "codex",
  "environment": {
    "allow_vars": [
      "NONO_PROXY_TOKEN",
      "GITHUB_TOKEN",
      "CONTEXT7_API_KEY",
      "EXA_API_KEY",
      "OPENAI_API_KEY"
    ]
  },
  "network": {
    "credentials": [
      "github",
      "context7",
      "openai"
    ],
    "custom_credentials": {
      "github": {
        "upstream": "https://api.github.com",
        "credential_key": "env://GITHUB_TOKEN",
        "env_var": "GITHUB_TOKEN",
        "inject_header": "Authorization",
        "credential_format": "token {}"
      },
      "context7": {
        "upstream": "https://api.context7.com",
        "credential_key": "env://CONTEXT7_API_KEY",
        "env_var": "CONTEXT7_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "openai": {
        "upstream": "https://api.openai.com",
        "credential_key": "env://OPENAI_API_KEY",
        "env_var": "OPENAI_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      }
    }
  }
}
