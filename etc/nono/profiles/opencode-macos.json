{
  "meta": {
    "name": "opencode-macos",
    "description": "OpenCode (macOS)"
  },
  "extends": "opencode",
  "filesystem": {
    "read": [
      "$HOME/Library/Caches/bun",
      "$HOME/Library/Application Support/Zed"
    ],
    "read_file": [
      "$HOME/.CFUserTextEncoding",
      "$HOME/Library/Keychains/login.keychain-db"
    ],
    "suppress_save_prompt": [
      "/Users"
    ],
    "bypass_protection": [
      "$HOME/Library/Keychains/login.keychain-db"
    ]
  },
  "environment": {
    "allow_vars": [
      "NONO_PROXY_TOKEN"
    ]
  },
  "network": {
    "credentials": [
      "github",
      "context7",
      "exa",
      "opencode",
      "zai",
      "minimax"
    ],
    "custom_credentials": {
      "github": {
        "upstream": "https://api.github.com",
        "credential_key": "github_token",
        "env_var": "GITHUB_TOKEN",
        "inject_header": "Authorization",
        "credential_format": "token {}"
      },
      "context7": {
        "upstream": "https://api.context7.com",
        "credential_key": "context7_api_key",
        "env_var": "CONTEXT7_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "exa": {
        "upstream": "https://api.exa.ai",
        "credential_key": "exa_api_key",
        "env_var": "EXA_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "opencode": {
        "upstream": "https://api.opencode.ai",
        "credential_key": "opencode_api_key",
        "env_var": "OPENCODE_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "zai": {
        "upstream": "https://api.z.ai/api/coding/paas/v4",
        "credential_key": "zai_api_key",
        "env_var": "ZAI_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      },
      "minimax": {
        "upstream": "https://api.minimax.io/v1",
        "credential_key": "minimax_api_key",
        "env_var": "MINIMAX_API_KEY",
        "inject_header": "Authorization",
        "credential_format": "Bearer {}"
      }
    }
  },
  "unsafe_macos_seatbelt_rules": [
    "(allow user-preference-read)"
  ]
}
