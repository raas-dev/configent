{
  "meta": {
    "name": "pi",
    "description": "Pi Coding Agent"
  },
  "extends": "default",
  "groups": {
    "include": [
      "git_config"
    ]
  },
  "filesystem": {
    "allow": [
      "$WORKDIR",
      "$HOME/.pi",
      "$HOME/.pi-lens",
      "$HOME/.config/configent/pi",
      "$HOME/.npm",
      "/tmp"
    ],
    "read": [
      "$HOME/.agents",
      "$HOME/.local/share/mise",
      "$HOME/.local/configent/bin",
      "$HOME/.config/configent/mcp"
    ],
    "read_file": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile",
      "$HOME/.npmrc",
      "$HOME/.CFUserTextEncoding"
    ],
    "bypass_protection": [
      "$HOME/.zshrc",
      "$HOME/.zprofile",
      "$HOME/.bashrc",
      "$HOME/.bash_profile",
      "$HOME/.profile",
      "$HOME/.npmrc"
    ]
  },
  "environment": {
    "allow_vars": [
      "PATH",
      "HOME",
      "USER",
      "SHELL",
      "TMPDIR",
      "LANG",
      "TERM",
      "COLORTERM",
      "TERM_PROGRAM",
      "TERM_PROGRAM_VERSION",
      "NO_COLOR",
      "FORCE_COLOR",
      "EMAIL",
      "GIT_AUTHOR_NAME",
      "GIT_COMMITTER_NAME",
      "GITHUB_TOKEN",
      "CONTEXT7_API_KEY",
      "EXA_API_KEY",
      "DYNAMIC_MCP_CONFIG",
      "PI_OFFLINE",
      "PI_RUN_CODE_UNSANDBOXED",
      "MINIMAX_API_KEY",
      "ZAI_API_KEY"
    ]
  },
  "network": {
    "block": false
  },
  "unsafe_macos_seatbelt_rules": [
    "(allow user-preference-read)"
  ]
}
