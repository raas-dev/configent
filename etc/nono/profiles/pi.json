{
  "meta": {
    "name": "pi",
    "version": "1.0.0",
    "description": "pi AI coding platform (ZAI/GLM via api.z.ai)"
  },
  "groups": {
    "include": ["git_config"]
  },
  "filesystem": {
    "allow": ["$WORKDIR", "$HOME/.pi", "$HOME/.agents", "$HOME/.pi-lens", "$HOME/configent/etc/pi"],
    "deny": ["$HOME/.rclocal"],
    "read": ["$HOME/configent/dotfiles"],
    "bypass_protection": [
      "$HOME/configent/dotfiles/.zshrc",
      "$HOME/configent/dotfiles/.bashrc",
      "$HOME/configent/dotfiles/.bash_profile",
      "$HOME/configent/dotfiles/.profile"
    ]
  },
  "network": {
    "block": false
  },
  "env_credentials": {
    "env://ZAI_API_KEY": "ZAI_API_KEY"
  },
  "unsafe_macos_seatbelt_rules": [
    "(allow file-read-metadata file-read-data (subpath \"/Users\"))"
  ]
}
