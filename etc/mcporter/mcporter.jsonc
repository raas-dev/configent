{
  "$schema": "https://raw.githubusercontent.com/steipete/mcporter/main/mcporter.schema.json",
  "mcpServers": {
    "exa": {
      "url": "https://mcp.exa.ai/mcp"
    },
    "gh-grep": {
      "url": "https://mcp.grep.app"
    },
    "skillseeker": {
      "command": "uvx",
      "args": [
        "--from",
        "skill-seekers[mcp]",
        "python",
        "-m",
        "skill_seekers.mcp.server_fastmcp"
      ]
    }
  },
  "imports": []
}
