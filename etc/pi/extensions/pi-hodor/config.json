{
  "enabled": true,
  "retryMessage": "continue",
  "maxConsecutiveAutoRetries": 99,
  "notifyOnAutoContinue": true,
  "autoContinueOnLength": true,
  "autoContinueOnThinkingOnlyStop": true,
  "autoContinueOnSilentStopAfterTool": true,
  "errorPatterns": [
    "error decoding response body",
    "stream disconnected before completion",
    "stream closed before",
    "stream closed unexpectedly",
    "stream interrupted",
    "stream ended unexpectedly",
    "premature close",
    "socket hang up",
    "connection reset by peer",
    "connection reset",
    "read ECONNRESET",
    "ECONNRESET",
    "ETIMEDOUT",
    "fetch failed",
    "unexpected end of JSON input",
    "unexpected end of input",
    "Error: 500 Internal network failure",
    "Error: The socket connection was closed unexpectedly.",
    "invalid params, tool call result does not follow tool call"
  ]
}
