{
  "name": "pi-run-code",
  "version": "0.1.0",
  "description": "Run JavaScript/TypeScript code within PI coding agent",
  "keywords": [
    "pi-package",
    "pi-extension",
    "code-mode"
  ],
  "license": "MIT",
  "homepage": "https://github.com/asyrjasalo/pi-run-code",
  "repository": {
    "type": "git",
    "url": "https://github.com/asyrjasalo/pi-run-code.git"
  },
  "type": "commonjs",
  "files": [
    "src/",
    "test/"
  ],
  "scripts": {
    "test": "node test/run.js"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "esbuild": "^0.27.3",
    "fs-extra": "^11.3.4",
    "typescript": "^5.9.3",
    "zx": "^8.8.5"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-agent-core": "*",
    "@sinclair/typebox": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-agent-core": "*",
    "@sinclair/typebox": "*",
    "@mariozechner/pi-tui": "*"
  }
}
