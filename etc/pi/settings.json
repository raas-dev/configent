{
  "autocompleteMaxVisible": 15,
  "collapseChangelog": true,
  "compaction": {
    "enabled": true
  },
  "defaultModel": "glm-5.1",
  "defaultProvider": "zai",
  "defaultThinkingLevel": "medium",
  "doubleEscapeAction": "tree",
  "enabledModels": [
    "zai/glm-5*",
    "minimax/MiniMax-M2.7"
  ],
  "enableInstallTelemetry": false,
  "hideThinkingBlock": false,
  "lastChangelogVersion": "0.70.2",
  "packages": [
    "npm:pi-ask-user",
    "npm:pi-headroom",
    "npm:pi-hodor",
    "npm:pi-image-tools",
    "npm:pi-manage-todo-list",
    "npm:pi-markdown-preview",
    "npm:pi-mcp-adapter",
    "npm:pi-mono-status-line",
    "npm:pi-rewind-hook",
    "npm:pi-rtk-optimizer",
    "npm:pi-token-burden",
    "npm:pi-tool-display",
    "npm:pi-web-access",
    "npm:@aliou/pi-processes",
    "npm:@latent-variable/pi-auto-continue",
    "npm:@ogulcancelik/pi-ghost",
    "npm:@ogulcancelik/pi-sketch",
    "npm:@siddr/pi-review",
    "npm:@sting8k/pi-vcc",
    "git:github.com/asyrjasalo/pi-run-code",
    "git:github.com/iodic/pi-ayu-themes",
    "git:github.com/jonjonrankin/pi-caveman",
    {
      "extensions": [
        "extensions/anycopy/index.ts",
        "extensions/branch-out/index.ts",
        "extensions/editor-enhancements/index.ts",
        "extensions/handover/index.ts",
        "extensions/model-aware-compaction/index.ts",
        "extensions/session-switch/index.ts",
        "extensions/tools/index.ts",
        "extensions/files-touched.ts",
        "extensions/fork-from-first.ts",
        "extensions/md.ts",
        "extensions/move-session.ts",
        "extensions/plan-mode.ts"
      ],
      "source": "git:github.com/asyrjasalo/pi-extensions"
    }
  ],
  "powerline": "default",
  "quietStartup": true,
  "rewind": {
    "retention": {
      "maxAgeDays": 30,
      "maxSnapshots": 2000,
      "pinLabeledEntries": true
    },
    "silentCheckpoints": true
  },
  "showHardwareCursor": true,
  "steeringMode": "all",
  "theme": "ayu-dark",
  "transport": "auto",
  "treeFilterMode": "user-only"
}
