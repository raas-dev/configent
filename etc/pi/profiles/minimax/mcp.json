{
  "mcpServers": {
    "minimax-vision": {
      "command": "uvx",
      "args": [
        "minimax-coding-plan-mcp",
        "-y"
      ],
      "env": {
        "MINIMAX_API_KEY": "${MINIMAX_API_KEY}",
        "MINIMAX_API_HOST": "https://api.minimax.io"
      },
      "lifecycle": "lazy",
      "directTools": true
    }
  },
  "settings": {
    "toolPrefix": "none"
  }
}
