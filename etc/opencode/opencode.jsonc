{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
    "dynamic-mcp": {
      "command": [
        "dmcp"
      ],
      "type": "local"
    }
  },
  "provider": {
    "ag": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ag",
      "options": {
        "baseURL": "http://headroom:8888",
        "apiKey": "{env:ONECLI_TOKEN}"
      },
      "models": {
        "MiniMax-M3": {
          "name": "MiniMax-M3",
          "limit": {
            "context": 1000000,
            "output": 128000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "video"
            ],
            "output": [
              "text"
            ]
          },
          "temperature": true,
          "tool_call": true,
          "reasoning": true,
          "attachment": true
        },
        "glm-5.2": {
          "name": "GLM-5.2",
          "limit": {
            "context": 1000000,
            "output": 131072
          },
          "modalities": {
            "input": [
              "text"
            ],
            "output": [
              "text"
            ]
          },
          "temperature": true,
          "tool_call": true,
          "reasoning": true,
          "attachment": false,
          "structured_output": true
        }
      }
    }
  },
  "permission": {
    "external_directory": "allow",
    "read": {
      "*": "allow"
    }
  },
  "plugin": [
    "caveman-opencode-plugin",
    "context-mode",
    "opencode-todo-reminder",
    "opencode-pty",
    "@dietrichgebert/ponytail",
    "@franlol/opencode-md-table-formatter",
    "@prevalentware/opencode-goal-plugin",
    "@tarquinen/opencode-dcp",
    "superpowers@git+https://github.com/obra/superpowers.git"
  ],
  "share": "disabled",
  "experimental": {
    "disable_paste_summary": true
  }
}
