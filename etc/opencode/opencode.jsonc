{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "mcp": {
    "dynamic-mcp": {
      "command": [
        "dmcp"
      ],
      "type": "local"
    }
  },
  "permission": {
    "external_directory": "allow"
  },
  "plugin": [
    "caveman-opencode-plugin",
    "@franlol/opencode-md-table-formatter",
    "@tarquinen/opencode-dcp",
    [
      "opencode-auto-resume",
      {
        "chunkTimeoutMs": 90000,
        "gracePeriodMs": 6000,
        "maxBackoffMs": 16000,
        "loopMaxContinues": 2
      }
    ]
  ],
  "share": "disabled"
}
