{
  "$schema": "https://unpkg.com/oh-my-opencode-slim@latest/oh-my-opencode-slim.schema.json",
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60
  },
  "disabled_mcps": [
    "context7",
    "websearch",
    "grep_app"
  ],
  "preset": "zai-plan",
  "presets": {
    "zai-plan": {
      "orchestrator": {
        "model": "zai-coding-plan/glm-5.1",
        "variant": "high",
        "skills": ["*"],
        "mcps": ["*"]
      },
      "explorer": {
        "model": "zai-coding-plan/glm-5.1",
        "variant": "low",
        "skills": ["*"],
        "mcps": [""]
      },
      "oracle": {
        "model": "zai-coding-plan/glm-5.1",
        "variant": "high",
        "skills": ["*"],
        "mcps": [""]
      },
      "librarian": {
        "model": "zai-coding-plan/glm-5.1",
        "variant": "low",
        "skills": ["*"],
        "mcps": ["*"]
      },
      "designer": {
        "model": "zai-coding-plan/glm-5.1",
        "variant": "medium",
        "skills": ["*"],
        "mcps": [""]
      },
      "fixer": {
        "model": "zai-coding-plan/glm-5.1",
        "variant": "low",
        "skills": ["*"],
        "mcps": [""]
      },
      "councillor": {
        "model": "zai-coding-plan/glm-5.1",
        "variant": "low",
        "skills": ["*"],
        "mcps": [""]
      }
    }
  },
  "council": {
    "master": {
      "model": "zai-coding-plan/glm-5.1"
    },
    "councillor_execution_mode": "serial",
    "presets": {
      "default": {
        "alpha": {
          "model": "zai-coding-plan/glm-5.1"
        },
        "beta": {
          "model": "zai-coding-plan/glm-5.1"
        },
        "gamma": {
          "model": "zai-coding-plan/glm-5.1"
        }
      }
    }
  }
}
