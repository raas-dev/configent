{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai-coding-plan/glm-5.1",
  "plugin": [
    "opencode-pty",
    [
      "@prevalentware/opencode-goal-plugin",
      {
        "auto_continue": true,
        "max_auto_turns": 25,
        "min_continue_interval_seconds": 3,
        "max_prompt_failures": 3
      }
    ]
  ]
}
