{
  "$schema": "https://opencode.ai/config.json",
  "model": "zai-coding-plan/glm-5-turbo",
  "permission": {
    "external_directory": "allow",
    "skill": {
      "agent-browser": "deny"
    }
  },
  "mcp": {
    "opentabs": {
      "type": "local",
      "command": [
        "opentabs",
        "start",
        "--stdio"
      ]
    }
  },
  "plugin": [
    "opencode-pty",
    "opencode-scheduler"
  ]
}
