{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "dynamic-mcp": {
      "command": [
        "dmcp"
      ],
      "type": "local"
    }
  },
  "model": "openai/gpt-5.4-mini",
  "plugin": [
    "opencode-pty",
    "opencode-scheduler",
    // see https://github.com/different-ai/opencode-browser for browser setup
    "@different-ai/opencode-browser"
  ]
}
