#!/bin/sh

# configent (https://github.com/raas-dev/configent)
# One command automated macOS/Linux laptop/VM/container bootstrapper.
#
# Copyright(C) 2016- Anssi Syrjäsalo (http://a.syrjasalo.com)
# Licensed under GNU Lesser General Public License v3 (LGPL-3.0).

trap "printf '\nCaught ^C from user - exiting now\n' ; exit 130" INT

rclocal_path="$HOME/.rclocal"
this_path="$(cd "$(dirname "$0")" && pwd)"

### files outside the repo #####################################################

touch "$rclocal_path"

# MISE_GITHUB_TOKEN is passed on lima VM create/start and is in /etc/environment
if ! grep -q "export GITHUB_TOKEN=" "$rclocal_path"; then
  printf "export GITHUB_TOKEN=\"\$MISE_GITHUB_TOKEN\"\n" >>"$rclocal_path"
fi

# Git identity
if ! grep -q "export EMAIL=" "$rclocal_path"; then
  git_email="${EMAIL:-$(git config --global user.email)}"
  printf "export EMAIL='%s'\n" "$git_email" >>"$rclocal_path"
fi
if ! grep -q "export GIT_AUTHOR_NAME=" "$rclocal_path"; then
  git_author_name="${GIT_AUTHOR_NAME:-$(git config --global user.name)}"
  printf "export GIT_AUTHOR_NAME='%s'\n" "$git_author_name" >>"$rclocal_path"
fi
if ! grep -q "export GIT_COMMITTER_NAME=" "$rclocal_path"; then
  git_committer_name="${GIT_COMMITTER_NAME:-$(git config --global user.name)}"
  printf "export GIT_COMMITTER_NAME='%s'\n" "$git_committer_name" >>"$rclocal_path"
fi

### files in the repo ##########################################################

"$this_path/symlink_dotfiles"
NONINTERACTIVE=true "$this_path/install_apps"
"$this_path/setup_ide"

printf "\n✅ bootstrap done.\n"
